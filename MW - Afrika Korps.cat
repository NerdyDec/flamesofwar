          <profiles>
            <profile id="546d-7cde-aa76-a264" name="Cut Them Down" hidden="false" typeId="c86b-12b3-c1b1-b8e0" typeName="Command Card [Revised]">
              <characteristics>
                <characteristic name="Details" typeId="fa11-60d9-4bb8-7538">Thie Formation Commander may re-roll failed To Hit rolls when Shooting during Defensive Fire while being assaulted.</characteristic>
              </characteristics>
