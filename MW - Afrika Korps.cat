              <characteristics>
                <characteristic name="Details" typeId="fa11-60d9-4bb8-7538">Increase this Formation Commander&apos;s Command Leadership distance from 6&quot;/15cm to 8&quot;/20cm.

Discard this card to automatically pass one Unit Last Stand Test for a Unit from this Formation whose Unit Leader is within 8&quot;/20cm of the Formation Commander.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="pts" typeId="995a-4d67-6920-bfe4" value="3.0"/>
          </costs>
        </selectionEntry>
