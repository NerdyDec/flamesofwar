        <selectionEntry id="0d11-1b58-4294-80ba" name="43rd (Wessex Division) - Cautious Not Stupid" hidden="false" collective="false" import="true" type="upgrade">
      <rules>
        <rule id="70c3-362d-d610-5cb6" name="Cautious Not Stupid" hidden="false">
          <description>During the Starting Step, when Rallying Pinned Down Units, you may discard this card to automatically Rally a Pinned Down Unit from this Formation.</description>
        </rule>
      </rules>
      <categoryLinks>
        <categoryLink id="ae57-dccd-d99e-9a08" name="Command Cards" hidden="false" targetId="c5b6-63ee-3f81-25f2" primary="false"/>
