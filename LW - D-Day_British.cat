  <profiles>
    <profile id="e7cd-f857-5d05-a5b0" name="AVRE Assault Bridge" typeId="5cbd-556d-67b5-1bd9" typeName="Command Card" hidden="false">
      <characteristics>
        <characteristic name="Details" typeId="4091-e11a-c858-f46e">While this card is face up the Unit Leader cannot Shoot or Assault.You may deploy this card at the end of any movement step, placing it face down completely within 4&quot;/10cm of the Unit Leader. This card becomes a bridge that can be used to cross a seawall, creek, stream, or river covered by this card at Tactical or Terrain Dash Speed.</characteristic>
        <characteristic name="Notes" typeId="75a6-20ee-1c76-640a">British, Build, Upgrade, Unit (AVRE Assault Section)</characteristic>
