      <characteristics>
        <characteristic name="Details" typeId="4091-e11a-c858-f46e">All Tank teams in this Unit have Mine Clearing Devices and may be given the Mine Clearing Order (see page 112 of the rulebook).</characteristic>
        <characteristic name="Notes" typeId="75a6-20ee-1c76-640a">British, Build, Upgrade, Unit (Sherman DD Armoured Troop)</characteristic>
