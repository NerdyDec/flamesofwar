  <profiles>
    <profile id="8132-d90b-ce64-c819" name="Stan Hollis" typeId="5cbd-556d-67b5-1bd9" typeName="Command Card" hidden="false">
      <characteristics>
        <characteristic name="Details" typeId="4091-e11a-c858-f46e">This Unit&apos;s Leader hits on a 2+ in Assaults. This Unit replaces the War Weary rating with the following rating,
MOTIVATIONStan HollisRally 2+
Any Unit from this Formation that has their Unit Leader within 6&quot;/15cm of this Unit&apos;s Leader, will Rally on a 3+.
MOTIVATIONStan HollisRally 3+</characteristic>
        <characteristic name="Notes" typeId="75a6-20ee-1c76-640a">British, Warrior, Unit (Rifle Platoon HQ)</characteristic>
