    <profile id="b336-be1a-2703-fdeb" name="Total Air Superiority" typeId="5cbd-556d-67b5-1bd9" typeName="Command Card" hidden="false">
      <characteristics>
        <characteristic name="Details" typeId="4091-e11a-c858-f46e">Fighter Interdiction: Your opponent must roll a 5+ for their aircraft to arrive (instead of the usual 4+).Perfect Timing:Discard this card before rolling. When Rolling for Aircraft arrival, your Aircraft arrive on a 3+ (instead of the usual 4+) this turn.</characteristic>
