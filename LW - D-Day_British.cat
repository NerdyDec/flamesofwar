  <rules>
    <rule id="ce2e-b08b-a4c6-7e14" name="Tommy Guns" hidden="false">
      <description>Exchange all Bren Gun &amp; SMLE rifle teams in this Unit with Mixed Weapon teams.</description>
    </rule>
  </rules>
