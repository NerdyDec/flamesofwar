</selectionEntry><selectionEntry id="6aa3-63b7-1c9c-b235" name="Sherman DD" hidden="false" collective="false" import="true" type="upgrade">
  <profiles>
    <profile id="1570-cdf9-461a-0618" name="Sherman DD" typeId="5cbd-556d-67b5-1bd9" typeName="Command Card" hidden="false">
      <characteristics>
        <characteristic name="Details" typeId="4091-e11a-c858-f46e">All Sherman tanks in this Unit gain Amphibious. The tank&apos;s MGs have a Moving and Halted ROF of 3. A Sherman cannot Shoot or Charge into Contact and Assault while it is in Impassable Water terrain.Amphibious: This vehicle treats Impassable Water as Difficult Terrain.</characteristic>
        <characteristic name="Notes" typeId="75a6-20ee-1c76-640a">British, Build, Upgrade, Unit (Sherman DD HQ, or Sherman DD Troop)</characteristic>
      </characteristics>
    </profile>
    <profile id="e7db-93ab-8e27-b952" name="Forces ID" typeId="86a9-a6ee-b9bd-dafe" typeName="Forces ID" hidden="false">
      <characteristics>
