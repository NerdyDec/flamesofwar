</selectionEntry><selectionEntry id="ced9-59ce-2e9d-a840" name="Sexton Field Troop" hidden="false" collective="false" import="true" type="upgrade">
  <profiles>
    <profile id="ba2f-6401-4855-0ba9" name="Sexton Field Troop" typeId="5cbd-556d-67b5-1bd9" typeName="Command Card" hidden="false">
      <characteristics>
        <characteristic name="Details" typeId="4091-e11a-c858-f46e">Your Force may replace any Priest Field Troop (LB116) with a Sexton Field Troop. The Sexton has the same ratings as the Priest except it has a different Armour rating and its weapons are:
            
                WeaponRangeROF HaltedROF MovingAnti- tankFire- power
                        Sexton (25 pdr)80&quot;/200cmARTILLERY34+
                        or Direct Fire24&quot;/60cm2193+
            
        ARMOURFRONT1SIDE &amp; REAR1TOP0The Sexton (25 pdr) has the Forward Firing rule. When firing as Artillery, it has the Mike Target and Smoke Bombardment special rules.</characteristic>
        <characteristic name="Notes" typeId="75a6-20ee-1c76-640a"/>
      </characteristics>
    </profile>
    <profile id="d8e7-ce31-f007-207d" name="Forces ID" typeId="86a9-a6ee-b9bd-dafe" typeName="Forces ID" hidden="false">
      <characteristics>
        <characteristic name="ID" typeId="846f-94be-be15-4936">383d9515-d8a9-52fe-979e-473f6a93e98e</characteristic>
      </characteristics>
    </profile>
  </profiles>
  <costs>
