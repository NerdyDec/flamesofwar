    </selectionEntry>
        <selectionEntry id="edcc-4e4c-28cc-ec51" name="Davide V. Currie" hidden="false" collective="false" import="true" type="upgrade">
      <rules>
        <rule id="1150-0211-43c8-c93d" name="Davide V. Currie" hidden="false">
          <description>This Commander&apos;s Leadership range is increased to 8&quot;/20cm instead of its normal 6&quot;/15cm.

This Formation Commander may roll two dice instead of one To Hit during Assaults.</description>
        </rule>
      </rules>
      <categoryLinks>
        <categoryLink id="f178-9125-c8e0-d322" name="Command Cards" hidden="false" targetId="c5b6-63ee-3f81-25f2" primary="false"/>
