      <characteristics>
        <characteristic name="Details" typeId="4091-e11a-c858-f46e">This Formation Commander and any Unit attached to it pass their Counterattack rolls on a 2+.This Formation Command hits on a 2+ in Assaults.</characteristic>
        <characteristic name="Notes" typeId="75a6-20ee-1c76-640a">British, Warrior, Formation (Parachute Company)</characteristic>
