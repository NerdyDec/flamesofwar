  <sharedRules>
    <rule id="6998-876f-198f-9c8e" name="Armoured Reserve" hidden="false">
      <description>In missions with Deep Reserves, you may only field one Tank Unit with Armoured Reserve, one Tank Unit with Front Armour of 3 or more, or one Aircraft Unit on the table at the start of the game.</description>
    </rule>
    <rule id="fdf4-b280-0b79-3a03" name="Hunters" hidden="false">
      <description>Infantry Teams treat Snow, Woods, and Forests as Cross-country Dash instead of Terrain Dash.</description>
    </rule>
    <rule id="f624-57ae-b369-3f2f" name="Pioneers" hidden="false">
      <description>Teams cross Minefields on 2+.</description>
    </rule>
    <rule id="48dc-e552-d836-ccc7" name="HEAT" hidden="false">
      <description>Target Armour is not increased by +1 if it is more than 16&quot;/40cm away.</description>
    </rule>
  </sharedRules>
