<selectionEntries><selectionEntry id="c5ac-4e8d-300f-ec78" name="Command Cards" hidden="false" collective="false" import="true" type="upgrade"><selectionEntries><selectionEntry id="f744-f123-a338-9539" name="Pure Luck" hidden="false" collective="false" import="true" type="upgrade">
