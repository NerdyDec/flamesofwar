        <selectionEntry id="8c4e-eb4e-f0b8-81b2" name="Lucky" hidden="false" collective="false" import="true" type="upgrade">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="df20-fcbf-9f80-718d" type="max"/>
