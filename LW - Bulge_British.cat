      </constraints>
      <rules>
        <rule id="3dca-a970-1aeb-729e" name="Naval Gunfire" hidden="false">
          <description>Each Shooting Step, choose a Formation HQ Team or an Observer to request a Naval Gunfire bombardment. On a roll of 5+ they may Spot for a four-gun Naval Gunfire Bombardment using their own Skill rating and the following weapon stats:
(See &quot;Naval Gunfire&quot; profile)
Remove the Ranged In marker for this bombardment at the end of the Shooting Step.</description>
        </rule>
      </rules>
      <infoLinks>
        <infoLink id="7248-848c-e565-9ffe" name="Naval Gunfire" hidden="false" targetId="037a-753e-f868-8982" type="profile"/>
