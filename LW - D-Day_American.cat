</selectionEntry><selectionEntry id="1180-382b-2b05-796a" name="Div Arty, All In!" hidden="false" collective="false" import="true" type="upgrade">
  <profiles>
    <profile id="3048-bcfd-dc4a-64bf" name="Div Arty, All In!" typeId="5cbd-556d-67b5-1bd9" typeName="Command Card" hidden="false">
      <characteristics>
        <characteristic name="Details" typeId="4091-e11a-c858-f46e">Before deployment, place up to three &apos;All In!&apos; Ranged In markers anywhere on the table.Discard this card during your Shooting Step to resolve a bombardment over each All In! Ranged In marker using a 105mm Field Artillery Battery (LU120). This is not a Repeat Bombardment, nor does it use the Time on Target rule.After the bombardments have been resolved, descard all of the All In! Ranged In markers.</characteristic>
        <characteristic name="Notes" typeId="75a6-20ee-1c76-640a">US, Force, Limited</characteristic>
      </characteristics>
    </profile>
    <profile id="06a6-9970-4e4e-1116" name="Forces ID" typeId="86a9-a6ee-b9bd-dafe" typeName="Forces ID" hidden="false">
