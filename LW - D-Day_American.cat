</selectionEntry><selectionEntry id="d887-b285-f21c-2b56" name="Naval Gunfire" hidden="false" collective="false" import="true" type="upgrade">
  <profiles>
    <profile id="b40f-1868-19d9-159e" name="Naval Gunfire" typeId="5cbd-556d-67b5-1bd9" typeName="Command Card" hidden="false">
      <characteristics>
        <characteristic name="Details" typeId="4091-e11a-c858-f46e">Each Shooting Step, choose a Formation HQ Team or an Observer to request a Naval Gunfire bombardment. On a roll of 5+ (or 4+ if the team is from  an Assault Company (LU137), Veteran Assault Company (LU143), or Ranger Company (LU134)), they may Spot for a four-gun Naval Gunfire Bombardment using their own Skill rating and the following weapon stats:RangeROFAnti-tankFire-powerUNLIMITEDARTILLERY4AUTORemoved the Ranged In marker for this bombardment at the end of the Shooting Step.</characteristic>
        <characteristic name="Notes" typeId="75a6-20ee-1c76-640a">US, Force, Limited</characteristic>
      </characteristics>
    </profile>
    <profile id="7b4e-b254-b98c-6556" name="Forces ID" typeId="86a9-a6ee-b9bd-dafe" typeName="Forces ID" hidden="false">
