  <profiles>
    <profile id="7498-f631-60af-5f78" name="370th Fighter Group" typeId="5cbd-556d-67b5-1bd9" typeName="Command Card" hidden="false">
      <characteristics>
        <characteristic name="Details" typeId="4091-e11a-c858-f46e">Discard this card after Ranging In to resolve this aircraft attack as Napalm Bombs, using the following characteristics:RangeROFAnti- tankFire- powerNOTES6&quot;/15cmARTILLERY1AUTONapalm BombsNapalm Bombs: No penalty for having only 1 or 2 weapons firing. Only Teams from this Unit can Spot for it. Infantry, Gun, and Unarmoured Tank Teams re-roll successful Saves. Armoured Tank Teams use Top armour for Saves.</characteristic>
        <characteristic name="Notes" typeId="75a6-20ee-1c76-640a">US, Build, Upgrade, Unit (P-47 Thunderbolt Fighter Flight), Limited</characteristic>
      </characteristics>
    </profile>
    <profile id="6089-f95f-9951-a181" name="Forces ID" typeId="86a9-a6ee-b9bd-dafe" typeName="Forces ID" hidden="false">
