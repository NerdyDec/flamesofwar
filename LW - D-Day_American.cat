  <profiles>
    <profile id="e368-1b78-c08b-40e5" name="8th Infantry Division Pathfinder" typeId="5cbd-556d-67b5-1bd9" typeName="Command Card" hidden="false">
      <characteristics>
        <characteristic name="Details" typeId="4091-e11a-c858-f46e">If this Force is the attacker in a mission where the defender has Minefields, you may attack at night.  If you do so, Night Fighting rules (see page 113 of the rulebook) are in effect at the start of the game.Units from this Formation can move freely from the start of the game.  Friendly Units from other Formations or Support may not move out of their Deployment until morning breaks.</characteristic>
        <characteristic name="Notes" typeId="75a6-20ee-1c76-640a">US, Build, Formation (Rifle Company), Title</characteristic>
      </characteristics>
    </profile>
    <profile id="7b71-b147-d393-d6c5" name="Forces ID" typeId="86a9-a6ee-b9bd-dafe" typeName="Forces ID" hidden="false">
