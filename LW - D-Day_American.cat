</selectionEntry><selectionEntry id="b552-a166-f29f-7225" name="Sandbag Armour" hidden="false" collective="false" import="true" type="upgrade">
  <profiles>
    <profile id="57b3-808e-98b9-107e" name="Sandbag Armour" typeId="5cbd-556d-67b5-1bd9" typeName="Command Card" hidden="false">
      <characteristics>
        <characteristic name="Details" typeId="4091-e11a-c858-f46e">All Tank teams in this Unit gain Sandbag Armour for +1 point per tank. The additional weight of the armour reduces all of the Tank’s Dash Speeds by 2”/5cm.
Sandbag Armour: If a tank in this Unit fails its Armour Save against a weapon with a Firepower rating of 5+ or 6, roll another die.On a roll of 5+ the Sandbag Armour stopped the shot. Ignore the failed save.Otherwise, resolve the hit as normal.</characteristic>
        <characteristic name="Notes" typeId="75a6-20ee-1c76-640a">US, Build, Upgrade, Unit (Tank)</characteristic>
      </characteristics>
    </profile>
    <profile id="5198-c472-9877-c7e5" name="Forces ID" typeId="86a9-a6ee-b9bd-dafe" typeName="Forces ID" hidden="false">
      <characteristics>
