      <comment>added in v1 by willus8888</comment>
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="c9bf-81a3-c6d1-5a80" type="max"/>
      </constraints>
      <profiles>
        <profile id="8070-0ab3-da74-7a97" name="Lucky" publicationId="afae-8f3f-0f99-8376" hidden="false" typeId="5cbd-556d-67b5-1bd9" typeName="Command Card">
          <comment>added in v1 by willus8888</comment>
          <characteristics>
            <characteristic name="Details" typeId="4091-e11a-c858-f46e">Discard this card to re-roll any one die. The second result must be used.</characteristic>
            <characteristic name="Notes" typeId="75a6-20ee-1c76-640a">US, Force, Limit</characteristic>
            <characteristic name="Info" typeId="bd5c-655e-1889-6af7"/>
          </characteristics>
        </profile>
      </profiles>
      <categoryLinks>
