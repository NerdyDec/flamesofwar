        <cost name="pts" typeId="995a-4d67-6920-bfe4" value="1.0"/>
      </costs>
    </selectionEntry>
        <selectionEntry id="a064-5c95-325c-1564" name="Tank Telephones" publicationId="afae-8f3f-0f99-8376" page="" hidden="false" collective="false" import="true" type="upgrade">
      <comment>added in v1 by willus8888</comment>
      <profiles>
        <profile id="348e-f987-f9ee-61b2" name="Tank Telephones" publicationId="afae-8f3f-0f99-8376" hidden="false" typeId="5cbd-556d-67b5-1bd9" typeName="Command Card">
          <comment>added in v1 by willus8888</comment>
          <characteristics>
            <characteristic name="Info" typeId="bd5c-655e-1889-6af7">Tank telephones were another field modification that saw a lot of use in the dense Bocage hedgerows of Normandy. There telephone boxes were welded to the back of the tank and gave the infantry a direct line of communication with the tank&apos;s commander. This greatly improved tank-infantry coordination on the battlefield</characteristic>
            <characteristic name="Details" typeId="4091-e11a-c858-f46e">If the Unit Leader is within 2&quot;/5cm of a Unit Leader from a friendly Infantry Unit, then one Tank in this Unit may re-roll one failed To Hit roll when targeting Infantry or Gun teams.</characteristic>
            <characteristic name="Notes" typeId="75a6-20ee-1c76-640a">US, Build, Upgrade, Unit (Any Veteran M4 Sherman or Veteran M5 Stuart Unit)</characteristic>
          </characteristics>
        </profile>
      </profiles>
      <categoryLinks>
        <categoryLink id="e4de-69be-01b1-00d0" name="New CategoryLink" hidden="false" targetId="c5b6-63ee-3f81-25f2" primary="true"/>
      </categoryLinks>
      <costs>
        <cost name="pts" typeId="995a-4d67-6920-bfe4" value="1.0"/>
      </costs>
    </selectionEntry>
        <selectionEntry id="05ab-cab0-0b9a-0b8d" name="2000 lbs Bomb Load" publicationId="afae-8f3f-0f99-8376" page="" hidden="false" collective="false" import="true" type="upgrade">
      <comment>added in v1 by willus8888</comment>
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="dd2e-e9e7-c30e-acc7" type="max"/>
      </constraints>
      <profiles>
        <profile id="43bc-c662-d9ee-fa16" name="2000 lbs Bomb Load" publicationId="afae-8f3f-0f99-8376" hidden="false" typeId="5cbd-556d-67b5-1bd9" typeName="Command Card">
          <comment>added in v1 by willus8888</comment>
          <characteristics>
            <characteristic name="Info" typeId="bd5c-655e-1889-6af7">The P-47 had an amazingly tough airframe that could carry up to a 2000 lb payload. This meant the Thunderbolt could carry several small bombs, rockets and its .50 cal machine-guns, or sometimes really big bombs</characteristic>
            <characteristic name="Details" typeId="4091-e11a-c858-f46e">Replace your Thunderbolts&apos; Bombs and Rockets with 1000 lb Bombs, using the following characteristics</characteristic>
            <characteristic name="Notes" typeId="75a6-20ee-1c76-640a">US, Build, Unit (P-47 Thunderbolt Fighter Flight)</characteristic>
          </characteristics>
        </profile>
        <profile id="fc85-f5ec-3f15-9ef2" name="1000 lb Bombs" publicationId="afae-8f3f-0f99-8376" hidden="false" typeId="33b6-a72a-2bd8-2565" typeName="Weapon">
          <characteristics>
            <characteristic name="Range" typeId="c2e5-4990-8105-f793">6&quot;/15cm</characteristic>
            <characteristic name="Halted ROF" typeId="7f6e-6f8f-5f15-6e9d">ARTILLERY</characteristic>
            <characteristic name="Moving ROF" typeId="f78e-b583-b3a5-754a">ARTILLERY</characteristic>
            <characteristic name="Anti-Tank" typeId="f57e-fa10-d0f9-e2dd">4</characteristic>
            <characteristic name="Firepower" typeId="9cf3-a34f-60d9-1309">2+</characteristic>
            <characteristic name="Notes" typeId="d939-5084-e654-44c6">Bombs</characteristic>
          </characteristics>
        </profile>
      </profiles>
      <categoryLinks>
        <categoryLink id="dae3-4763-d985-523f" name="New CategoryLink" hidden="false" targetId="c5b6-63ee-3f81-25f2" primary="true"/>
      </categoryLinks>
      <costs>
        <cost name="pts" typeId="995a-4d67-6920-bfe4" value="1.0"/>
      </costs>
    </selectionEntry>
        <selectionEntry id="26e5-addc-e68d-860c" name="Ronald Speirs" publicationId="afae-8f3f-0f99-8376" page="" hidden="false" collective="false" import="true" type="upgrade">
      <comment>added in v1 by willus8888</comment>
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="cbcb-c9b6-5fb7-d34e" type="max"/>
      </constraints>
      <profiles>
        <profile id="2583-5167-89cd-cc8c" name="Ronald Speirs" publicationId="afae-8f3f-0f99-8376" hidden="false" typeId="5cbd-556d-67b5-1bd9" typeName="Command Card">
          <comment>added in v1 by willus8888</comment>
          <characteristics>
            <characteristic name="Info" typeId="bd5c-655e-1889-6af7">When Captain Winters saw Easy Company&apos;s assault on Foy come to a halt due to Lieutenant Norman Dike&apos;s poor leadership, he spun around and ordered the first officer to come into view to go and relieve Dike and finish the assault. That man happened to be Speirs, who instantly sprang into action and carried the men to victory</characteristic>
            <characteristic name="Details" typeId="4091-e11a-c858-f46e">If this Formation Commander is not in Bulletproof Cover, he may re-roll failed Infantry Saves for each Hit he takes.
This FOrmation Commander may be held in Ambush at the start of the game. When you reveal Ambushes, place the Commander within 6&quot;/15cm of any teams of a Bastogne Parachute Rifle Platoon, and not within 4&quot;/10cm of enemy teams</characteristic>
            <characteristic name="Notes" typeId="75a6-20ee-1c76-640a">US, Warrior, Formation (Bastogne Parachute Rifle Company)</characteristic>
          </characteristics>
        </profile>
      </profiles>
      <categoryLinks>
        <categoryLink id="c198-ea6d-9f26-0f3e" name="New CategoryLink" hidden="false" targetId="c5b6-63ee-3f81-25f2" primary="true"/>
      </categoryLinks>
      <costs>
        <cost name="pts" typeId="995a-4d67-6920-bfe4" value="3.0"/>
      </costs>
    </selectionEntry>
        <selectionEntry id="dff0-ba12-b482-77ff" name="Sticky Bombs" publicationId="afae-8f3f-0f99-8376" page="" hidden="false" collective="false" import="true" type="upgrade">
      <comment>added in v1 by willus8888</comment>
      <profiles>
        <profile id="5804-544d-9645-4add" name="Sticky Bombs" publicationId="afae-8f3f-0f99-8376" hidden="false" typeId="5cbd-556d-67b5-1bd9" typeName="Command Card">
          <comment>added in v1 by willus8888</comment>
          <characteristics>
            <characteristic name="Info" typeId="bd5c-655e-1889-6af7">Paratroopers expected to be fighting behind enemy lines for a long time. This meant that they had to have solutions for dealing with enemy armour in close quarters combat. This typically involved a lot of grit and a touch of TNT</characteristic>
            <characteristic name="Details" typeId="4091-e11a-c858-f46e">Discard this card to give Infantry teams in this Unit Anti-tank 3 and Firepower +1 against Top Armour in Assualts until the end of the turn.</characteristic>
            <characteristic name="Notes" typeId="75a6-20ee-1c76-640a">US, Unit (Bastogne Parachute Rifle Platoon)</characteristic>
          </characteristics>
        </profile>
      </profiles>
      <categoryLinks>
        <categoryLink id="94c9-c73e-5e94-3dfd" name="New CategoryLink" hidden="false" targetId="c5b6-63ee-3f81-25f2" primary="true"/>
      </categoryLinks>
      <costs>
        <cost name="pts" typeId="995a-4d67-6920-bfe4" value="2.0"/>
      </costs>
    </selectionEntry>
        <selectionEntry id="c127-25a7-15e8-1e5c" name="Julian Cook" publicationId="afae-8f3f-0f99-8376" page="" hidden="false" collective="false" import="true" type="upgrade">
      <comment>added in v1 by willus8888</comment>
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="ca6c-3dce-6449-e2e1" type="max"/>
      </constraints>
      <profiles>
        <profile id="cb87-c09f-f244-688f" name="Julian Cook" publicationId="afae-8f3f-0f99-8376" hidden="false" typeId="5cbd-556d-67b5-1bd9" typeName="Command Card">
          <comment>added in v1 by willus8888</comment>
          <characteristics>
            <characteristic name="Info" typeId="bd5c-655e-1889-6af7">Major Cook jumped into Holland at DZ &apos;O&apos; near the Maas-Waal Canal. After helping to secure the canal crossing. Cook and his men marched to Nijmegen. There, General Gavin ordered a daylight crossing of the Waal River to outflank the stubborn German defenders entrenched around the city&apos;s important bridges.
Cook was given command of the crossing and led his men in the first was across the river.
Once ashone, cook and hhis men cleared the river bank and assaulted both the railroad and highway bridges. After a sharp flight the 3rd Battalion, at 1900 hours, captured the bridge</characteristic>
            <characteristic name="Details" typeId="4091-e11a-c858-f46e">Any Unit from this Formation whose Unit Leader is within 6&quot;/15cm of the Formation Commander passes Tactics rolls on 2+</characteristic>
            <characteristic name="Notes" typeId="75a6-20ee-1c76-640a">US, Warrior, Formation (Bastogne Parachute Rifle Company)</characteristic>
          </characteristics>
        </profile>
      </profiles>
      <categoryLinks>
        <categoryLink id="0468-0a8a-1c0c-15d5" name="New CategoryLink" hidden="false" targetId="c5b6-63ee-3f81-25f2" primary="true"/>
      </categoryLinks>
      <costs>
        <cost name="pts" typeId="995a-4d67-6920-bfe4" value="2.0"/>
      </costs>
    </selectionEntry>
        <selectionEntry id="4246-1cdb-89f5-2808" name="Total Air Suoeriority" publicationId="afae-8f3f-0f99-8376" page="" hidden="false" collective="false" import="true" type="upgrade">
      <comment>added in v1 by willus8888</comment>
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="f6a8-8029-bb6c-0dc8" type="max"/>
      </constraints>
      <profiles>
        <profile id="fdc7-c59f-5f38-1439" name="Total Air Suoeriority" publicationId="afae-8f3f-0f99-8376" hidden="false" typeId="5cbd-556d-67b5-1bd9" typeName="Command Card">
          <comment>added in v1 by willus8888</comment>
          <characteristics>
            <characteristic name="Info" typeId="bd5c-655e-1889-6af7">The US Army Air FOrce and the British Royal Air Force continued to have total control of the skies over western Europe as Allied armies moved into eastern France and beyond the German border</characteristic>
            <characteristic name="Details" typeId="4091-e11a-c858-f46e">Fighter Interdiction: Your opponent must roll a +5 for their aircraft to arrive (instead of the usual 4+)

Perfect Timing: Discard this card before rolling. When Rolling for Aircraft arrival, your Aircraft Arrive on a 3+ (instead of the usual 4+) this turn</characteristic>
            <characteristic name="Notes" typeId="75a6-20ee-1c76-640a">US, Force, Limited</characteristic>
          </characteristics>
        </profile>
      </profiles>
      <categoryLinks>
        <categoryLink id="0067-fd80-f157-c6e7" name="New CategoryLink" hidden="false" targetId="c5b6-63ee-3f81-25f2" primary="true"/>
      </categoryLinks>
      <costs>
        <cost name="pts" typeId="995a-4d67-6920-bfe4" value="3.0"/>
      </costs>
    </selectionEntry>
        <selectionEntry id="ca2d-f9b9-8dc0-80f5" name="WIP Improvised Turret Top Armour" publicationId="afae-8f3f-0f99-8376" page="" hidden="false" collective="false" import="true" type="upgrade">
      <comment>added in v1 by willus8888</comment>
      <profiles>
        <profile id="c221-5248-9840-f0f0" name="Improvised Turret Top Armour" publicationId="afae-8f3f-0f99-8376" hidden="false" typeId="5cbd-556d-67b5-1bd9" typeName="Command Card">
          <comment>added in v1 by willus8888</comment>
          <characteristics>
            <characteristic name="Info" typeId="bd5c-655e-1889-6af7">Some Tank Destroyer crews found their turret crews were suffering higher casualties during combat while they were exposed to the open fire air. To remedy this some battalion workshops improvised turret top armour from captured vehicles</characteristic>
            <characteristic name="Details" typeId="4091-e11a-c858-f46e">Give Tank teams in this Unit Top Armour 1 for +1 point per Unit</characteristic>
            <characteristic name="Notes" typeId="75a6-20ee-1c76-640a">US, Build, Upgrade, Unit (M36 Tank Destroyer Platoon, M10 Tank Destroyer Platoon, M36B1 Tank Destroyer Platoon)</characteristic>
          </characteristics>
        </profile>
      </profiles>
      <categoryLinks>
        <categoryLink id="f4c1-d0ad-8bbf-e5d9" name="New CategoryLink" hidden="false" targetId="c5b6-63ee-3f81-25f2" primary="true"/>
      </categoryLinks>
      <costs>
        <cost name="pts" typeId="995a-4d67-6920-bfe4" value="0.0"/>
      </costs>
    </selectionEntry>
        <selectionEntry id="3052-3346-7391-9e62" name="57mm High-Explosive" publicationId="afae-8f3f-0f99-8376" page="" hidden="false" collective="false" import="true" type="upgrade">
      <comment>added in v1 by willus8888</comment>
      <profiles>
        <profile id="cd3b-57f7-130e-83c3" name="57mm High-Explosive" publicationId="afae-8f3f-0f99-8376" hidden="false" typeId="5cbd-556d-67b5-1bd9" typeName="Command Card">
          <comment>added in v1 by willus8888</comment>
          <characteristics>
            <characteristic name="Info" typeId="bd5c-655e-1889-6af7">By the end of 1944 the M1 57mm anti-tank guns were being issued high-explosive rounds to be used against enemy infantry and guns</characteristic>
            <characteristic name="Details" typeId="4091-e11a-c858-f46e">All 57mm guns in this Unit remove No HE</characteristic>
            <characteristic name="Notes" typeId="75a6-20ee-1c76-640a">US, Build, Upgrade, Unit (Any 57mm Anti-tank platoon)</characteristic>
          </characteristics>
        </profile>
      </profiles>
      <categoryLinks>
        <categoryLink id="3429-8186-8a2d-6c4a" name="New CategoryLink" hidden="false" targetId="c5b6-63ee-3f81-25f2" primary="true"/>
      </categoryLinks>
      <costs>
        <cost name="pts" typeId="995a-4d67-6920-bfe4" value="0.0"/>
      </costs>
    </selectionEntry>
        <selectionEntry id="4c84-bfc5-7f7b-9dd7" name="James Gavin" publicationId="afae-8f3f-0f99-8376" page="" hidden="false" collective="false" import="true" type="upgrade">
      <comment>added in v1 by willus8888</comment>
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="d506-c5e0-63cb-7b38" type="max"/>
      </constraints>
      <profiles>
        <profile id="c555-d4e1-af55-f0b0" name="James Gavin" publicationId="afae-8f3f-0f99-8376" hidden="false" typeId="5cbd-556d-67b5-1bd9" typeName="Command Card">
          <comment>added in v1 by willus8888</comment>
          <characteristics>
            <characteristic name="Info" typeId="bd5c-655e-1889-6af7">During Market Garden Gavin&apos;s 82nd Airborne Division quickly secured the Grave bridge.
His next priority was to secure the Groesbeek Heights to protect his flank. However, when he finally turned his attention to Nijmegen the Germans had heavily reinforced the town. 
When the British 30 Corps arrived, Gavin implemented a bold river assualt on 20 September to capture the Nijmegen bridges . The plan was a success and by dawn the next day, 30 Corps was back on the road to Arnhem</characteristic>
            <characteristic name="Details" typeId="4091-e11a-c858-f46e">After your opponent rolls to receive Reserves, roll a die for each Unit you still have in Reserve. For each result of 6, your opponent must ignore a successful die result to receive Reserves this turn</characteristic>
            <characteristic name="Notes" typeId="75a6-20ee-1c76-640a">US, Warrior, Formation (Bastogne Parachute Rifle Company)</characteristic>
          </characteristics>
        </profile>
      </profiles>
      <categoryLinks>
        <categoryLink id="7a58-8cef-6e5c-36fe" name="New CategoryLink" hidden="false" targetId="c5b6-63ee-3f81-25f2" primary="true"/>
      </categoryLinks>
      <costs>
        <cost name="pts" typeId="995a-4d67-6920-bfe4" value="3.0"/>
      </costs>
    </selectionEntry>
        <selectionEntry id="6bf2-1fc0-1689-b27f" name="Carwood Lipton" publicationId="afae-8f3f-0f99-8376" page="" hidden="false" collective="false" import="true" type="upgrade">
      <comment>added in v1 by willus8888</comment>
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="de24-e2ed-f898-8930" type="max"/>
      </constraints>
      <profiles>
        <profile id="88ae-6ab0-8c9d-3716" name="Carwood Lipton" publicationId="afae-8f3f-0f99-8376" hidden="false" typeId="5cbd-556d-67b5-1bd9" typeName="Command Card">
          <comment>added in v1 by willus8888</comment>
          <characteristics>
            <characteristic name="Info" typeId="bd5c-655e-1889-6af7">In Normandy, Lipton linked up with Winters and together they prepared for the assault on Brecourt Manor, during which he earned a Bronze Star. Following the fighting in Normandy, Lipton was promoted to First Sergeant of Easy Company. As First Sergeant, Lipton had his ear to the ground to help address the men&apos;s worries and fears</characteristic>
            <characteristic name="Details" typeId="4091-e11a-c858-f46e">Any Unit from this formation whose Unit Leader is within 6&quot;/15cm of the Formation Commander pass Rally rolls on 2+</characteristic>
            <characteristic name="Notes" typeId="75a6-20ee-1c76-640a">US, Warrior, Formation (Bastogne Parachute Rifle Company)</characteristic>
          </characteristics>
        </profile>
      </profiles>
      <categoryLinks>
        <categoryLink id="3cb6-07b7-39db-6506" name="New CategoryLink" hidden="false" targetId="c5b6-63ee-3f81-25f2" primary="true"/>
      </categoryLinks>
      <costs>
        <cost name="pts" typeId="995a-4d67-6920-bfe4" value="2.0"/>
      </costs>
    </selectionEntry>
        <selectionEntry id="fe26-860a-a933-b508" name="WIP Softskin Transport" publicationId="afae-8f3f-0f99-8376" page="" hidden="false" collective="false" import="true" type="upgrade">
      <comment>added in v1 by willus8888</comment>
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="ec2c-6de2-5c7e-6c2c" type="max"/>
      </constraints>
      <profiles>
        <profile id="d791-be7f-6c20-08d6" name="Softskin Transport" publicationId="afae-8f3f-0f99-8376" hidden="false" typeId="5cbd-556d-67b5-1bd9" typeName="Command Card">
          <comment>added in v1 by willus8888</comment>
          <characteristics>
            <characteristic name="Info" typeId="bd5c-655e-1889-6af7">The United States built more trucks than the rest of the world combined. These moved their Infantry and artillery on long-distance road marches</characteristic>
            <characteristic name="Details" typeId="4091-e11a-c858-f46e">This Infantry or Gun Unit may add a Softskin Transport Attachment. The number of vehicles in the Unit is as follows:

• Add one Softskin Transport for every six Infantry Teams in the Unit.

• Add one Softskin Transport Unit for each Gun Team in the Unit

The characteristics of a Softskin Transport are shown on the back of this card</characteristic>
            <characteristic name="Notes" typeId="75a6-20ee-1c76-640a">US, Build, Unit (Infantry or Gun)</characteristic>
          </characteristics>
        </profile>
      </profiles>
      <categoryLinks>
        <categoryLink id="72b2-ab37-d02b-732b" name="New CategoryLink" hidden="false" targetId="c5b6-63ee-3f81-25f2" primary="true"/>
      </categoryLinks>
      <costs>
        <cost name="pts" typeId="995a-4d67-6920-bfe4" value="1.0"/>
      </costs>
    </selectionEntry>
        <selectionEntry id="d595-8b08-e8d5-3efc" name="WIP Amphibious Transport" publicationId="afae-8f3f-0f99-8376" page="" hidden="false" collective="false" import="true" type="upgrade">
      <comment>added in v1 by willus8888</comment>
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="653c-a4f4-a872-12cc" type="max"/>
      </constraints>
      <profiles>
        <profile id="645b-d035-dc68-d95e" name="Amphibious Transport" publicationId="afae-8f3f-0f99-8376" hidden="false" typeId="5cbd-556d-67b5-1bd9" typeName="Command Card">
          <comment>added in v1 by willus8888</comment>
          <characteristics>
            <characteristic name="Info" typeId="bd5c-655e-1889-6af7">The DUKW (colloquially known as Duck) is a six-wheel-drive amphibious modification of the standrard US 2 1/2 - ton truck. The DUKW proved execellent in its role as an amphibious transport  </characteristic>
            <characteristic name="Details" typeId="4091-e11a-c858-f46e">This Infantry or Gun Unit may add an Amphibious Transport Attachment. The number of vehicles in the Unit is as follows:

• Add one Amphibious Transport for every six Infantry Teams in the Unit.

• Add one Amphibious Transport Unit for each Gun Team in the Unit

The characteristics of a Amphibious Transport are shown on the back of this card</characteristic>
            <characteristic name="Notes" typeId="75a6-20ee-1c76-640a">US, Build, Unit (Infantry or Gun)</characteristic>
          </characteristics>
        </profile>
      </profiles>
      <categoryLinks>
        <categoryLink id="1a1b-7616-cccc-0e03" name="New CategoryLink" hidden="false" targetId="c5b6-63ee-3f81-25f2" primary="true"/>
      </categoryLinks>
      <costs>
        <cost name="pts" typeId="995a-4d67-6920-bfe4" value="1.0"/>
      </costs>
    </selectionEntry>
        <selectionEntry id="2eb5-cd6b-2da8-4bf2" name="M24 Chaffee Cavalry Tank Company" publicationId="afae-8f3f-0f99-8376" hidden="false" collective="false" import="true" type="upgrade">
      <comment>added in v1 by willus8888</comment>
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="03a6-ed70-bece-ca81" type="max"/>
      </constraints>
      <profiles>
        <profile id="a69b-0250-5146-dbd7" name="M24 Chaffee Cavalry Tank Company" publicationId="afae-8f3f-0f99-8376" hidden="false" typeId="5cbd-556d-67b5-1bd9" typeName="Command Card">
          <comment>added in v1 by willus8888</comment>
          <characteristics>
            <characteristic name="Info" typeId="bd5c-655e-1889-6af7">The US Cavalry provided the eyes and ears of the US Army</characteristic>
            <characteristic name="Details" typeId="4091-e11a-c858-f46e">Your Force includes one M24 Chaffee Cavalry Tank Company, which is a formation containing:

• 1 HQ Unit of 2x M24 Chaffee tanks from (LU197) for 8 points.

• 2-3 Veteran M24 Chaffee Tank Platoon (LU198)

• 0-2 M8 Greyhound Cavalry Recon Patrol (LU174), or M5 Stuart Cavalry Recon Patrol (LU231)

• 0-1 Veteran M8 Scott Assault Gun Platoon with 2 to 6 M8 Scott Assault guns from (LU170) for 2 points per tank</characteristic>
            <characteristic name="Notes" typeId="75a6-20ee-1c76-640a">US, Build, Formation, Limited</characteristic>
          </characteristics>
        </profile>
      </profiles>
      <categoryLinks>
        <categoryLink id="2189-89bb-ad67-d6dc" name="New CategoryLink" hidden="false" targetId="c5b6-63ee-3f81-25f2" primary="true"/>
      </categoryLinks>
      <costs>
        <cost name="pts" typeId="995a-4d67-6920-bfe4" value="0.0"/>
      </costs>
    </selectionEntry>
        <selectionEntry id="281b-d547-4ae9-b427" name="WIP 291st Engineer Combat Battalion Roadblock" publicationId="afae-8f3f-0f99-8376" page="" hidden="false" collective="false" import="true" type="upgrade">
      <comment>added in v1 by willus8888</comment>
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="c7e6-efaf-adf0-f523" type="max"/>
      </constraints>
      <profiles>
        <profile id="7104-5d64-9c3e-6ae6" name="291st Engineer Combat Battalion Roadblock" publicationId="afae-8f3f-0f99-8376" hidden="false" typeId="5cbd-556d-67b5-1bd9" typeName="Command Card">
          <comment>added in v1 by willus8888</comment>
          <characteristics>
            <characteristic name="Info" typeId="bd5c-655e-1889-6af7">Roadblocks formed the core of the engineers&apos; defence. Tpyically they would mine the road and its shoulders and set up trenches and gun pits covering the position</characteristic>
            <characteristic name="Details" typeId="4091-e11a-c858-f46e">You must take the Damned Engineers&apos; card before you can take the Roadblock card.

Roadblock: in a mission with Minefields you may also field one Anti-tank Obstacle per two Minefields and one Bardbed Wire Entanglement for each Minefield. You may also exchange one Minefield for four Booby Traps.

Anti-tank Obstacle: Anti-tank Obstacles are Difficult Terrain for all Infantry Teams moving within 2&quot;/5cm of a Anti-tank Obstacle marker. Anti-tank Obstacles are Impassible to Gun and Tank Teams</characteristic>
            <characteristic name="Notes" typeId="75a6-20ee-1c76-640a">US, Build, Force, TItle</characteristic>
          </characteristics>
        </profile>
      </profiles>
      <categoryLinks>
        <categoryLink id="6f2a-3d05-47c4-e93e" name="New CategoryLink" hidden="false" targetId="c5b6-63ee-3f81-25f2" primary="true"/>
      </categoryLinks>
      <costs>
        <cost name="pts" typeId="995a-4d67-6920-bfe4" value="10.0"/>
      </costs>
    </selectionEntry>
        <selectionEntry id="e315-ddd1-ceb7-e724" name="WIP 291st Engineer Combat Battalion Damned Engineers!" publicationId="afae-8f3f-0f99-8376" page="" hidden="false" collective="false" import="true" type="upgrade">
      <comment>added in v1 by willus8888</comment>
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="f116-88a0-82c8-e5a7" type="max"/>
      </constraints>
      <profiles>
        <profile id="76c5-d4d0-a833-6f28" name="291st Engineer Combat Battalion Damned Engineers!" publicationId="afae-8f3f-0f99-8376" hidden="false" typeId="5cbd-556d-67b5-1bd9" typeName="Command Card">
          <comment>added in v1 by willus8888</comment>
          <characteristics>
            <characteristic name="Info" typeId="bd5c-655e-1889-6af7">The combat engineers of the 291st Engineer Combat Battalion found themselves to be the only thing standing between SS-Kampfgruppe Peiper and the Meuse River</characteristic>
            <characteristic name="Details" typeId="4091-e11a-c858-f46e">Your Force includes one Engineer Combat Company, which is a Formation containing:

• 1 Bastogne Glider Rifle Company HQ (LU216)

• 2-3 Engineer Combat Platoon (from Engineer Combat Platoon card)

• 0-1 Bastogne Glider M1917 Machine-gun Platoon (LU218)

• 0-1 Bastogne Glider 57mm Anti-tank Platoon (LU220)

Pioneers: Infantry teams in the HQ Unit cross Minefields safely on a roll od 2+ and Dig In on a roll 2+</characteristic>
            <characteristic name="Notes" typeId="75a6-20ee-1c76-640a">US, Build, Formation, TItle</characteristic>
          </characteristics>
        </profile>
      </profiles>
      <categoryLinks>
        <categoryLink id="0cbc-cd83-7139-cd16" name="New CategoryLink" hidden="false" targetId="c5b6-63ee-3f81-25f2" primary="true"/>
      </categoryLinks>
      <costs>
        <cost name="pts" typeId="995a-4d67-6920-bfe4" value="1.0"/>
      </costs>
    </selectionEntry>
        <selectionEntry id="70a6-db5b-b359-f7be" name="Maxwell Taylor" publicationId="afae-8f3f-0f99-8376" page="" hidden="false" collective="false" import="true" type="unit">
      <comment>added in v1 by willus8888</comment>
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="a4ea-4a83-4370-f555" type="max"/>
      </constraints>
      <profiles>
        <profile id="11a4-f3d7-4ec7-d8c3" name="Maxwell Taylor" publicationId="afae-8f3f-0f99-8376" hidden="false" typeId="5cbd-556d-67b5-1bd9" typeName="Command Card">
          <comment>added in v1 by willus8888</comment>
          <characteristics>
            <characteristic name="Info" typeId="bd5c-655e-1889-6af7">When he was given the plan for Market Garden, general Maxwell Taylor knew that his 101st Airbourne Division was going to need to hold a rather large portion of the highway open for the British 30 Corps. To deal with this, he gave each of his regiments a point along the highway to another their defences upon. From these strongpoints the division would launch spoiling attacks against the Germans, keeping them occupied while 30 Corps charged north</characteristic>
            <characteristic name="Details" typeId="4091-e11a-c858-f46e">Bastogne Parachute Rifle Platoon and Bastogne Glider Rifle Platoons in this Force may use the Spearhead rule</characteristic>
            <characteristic name="Notes" typeId="75a6-20ee-1c76-640a">US, Warrior, Force</characteristic>
          </characteristics>
        </profile>
      </profiles>
      <categoryLinks>
        <categoryLink id="e8ec-948f-f113-f445" name="New CategoryLink" hidden="false" targetId="c5b6-63ee-3f81-25f2" primary="true"/>
      </categoryLinks>
      <costs>
        <cost name="pts" typeId="995a-4d67-6920-bfe4" value="5.0"/>
      </costs>
    </selectionEntry>
        <selectionEntry id="c617-8263-7b47-1162" name="Creighton Abrams" publicationId="afae-8f3f-0f99-8376" page="" hidden="false" collective="false" import="true" type="unit">
      <comment>added in v1 by willus8888</comment>
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="493c-a85b-524a-fbd2" type="max"/>
      </constraints>
      <profiles>
        <profile id="1c13-35e4-324c-25c7" name="Creighton Abrams" publicationId="afae-8f3f-0f99-8376" hidden="false" typeId="5cbd-556d-67b5-1bd9" typeName="Command Card">
          <comment>added in v1 by willus8888</comment>
          <characteristics>
            <characteristic name="Info" typeId="bd5c-655e-1889-6af7">Down to a mere 20 tanks and just five miles from Bastogne, Abrams sent a message to Patton: &quot;will you authorize a big risk with Combat Command R for a breakthrough to Bastogne?&quot; Patton&apos;s reply was instant. &quot;I sure as hell will!&quot;</characteristic>
            <characteristic name="Details" typeId="4091-e11a-c858-f46e">The Formation HQ Unit uses spearhead rule.

Any Unit whose Unit Leader is within 6&quot;/15cm of the Formation Commander may attempt a second Movement Order after succeesing in its first Movement Order. The second Movement Order must be different from the first</characteristic>
            <characteristic name="Notes" typeId="75a6-20ee-1c76-640a">US, Warrior, Formation (Veteran M4 Sherman (late) Tank Company)</characteristic>
          </characteristics>
        </profile>
      </profiles>
      <categoryLinks>
        <categoryLink id="648b-2772-6b23-3b65" name="New CategoryLink" hidden="false" targetId="c5b6-63ee-3f81-25f2" primary="true"/>
      </categoryLinks>
      <costs>
        <cost name="pts" typeId="995a-4d67-6920-bfe4" value="3.0"/>
      </costs>
    </selectionEntry>
        <selectionEntry id="9592-be3a-a5da-9341" name="George S. Patton Jr." publicationId="afae-8f3f-0f99-8376" page="" hidden="false" collective="false" import="true" type="unit">
      <comment>added in v1 by willus8888</comment>
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="896e-319b-a718-870d" type="max"/>
      </constraints>
      <profiles>
        <profile id="cee6-bd6e-d10e-775a" name="George S. Patton Jr." publicationId="afae-8f3f-0f99-8376" hidden="false" typeId="5cbd-556d-67b5-1bd9" typeName="Command Card">
          <comment>added in v1 by willus8888</comment>
          <characteristics>
            <characteristic name="Info" typeId="bd5c-655e-1889-6af7">&quot;We are advancing constantly and we are not interested in holding onto anything, except the enemy&apos;s balls. We are going to twist his balls and kick the living shit out of him all of the time... We are going to go through him like crap through a goose; like shit through a tin horn!&quot;

- George S Patton, Speech to the Third Army, 5 June 1944</characteristic>
            <characteristic name="Details" typeId="4091-e11a-c858-f46e">When a Unit Leader is within 8&quot;/20cm and Line of Sight of their Formation Commander, the Unit passes Rally or Remount on a 2+

Each turn you may re-roll one failed die roll to recieve Reserves</characteristic>
            <characteristic name="Notes" typeId="75a6-20ee-1c76-640a">US, Warrior, Force</characteristic>
          </characteristics>
        </profile>
      </profiles>
      <categoryLinks>
        <categoryLink id="0be8-c8bb-3343-4631" name="New CategoryLink" hidden="false" targetId="c5b6-63ee-3f81-25f2" primary="true"/>
      </categoryLinks>
      <costs>
        <cost name="pts" typeId="995a-4d67-6920-bfe4" value="4.0"/>
      </costs>
    </selectionEntry>
        <selectionEntry id="fec4-0d83-bd96-bc57" name="Outpost Machine-Guns" publicationId="afae-8f3f-0f99-8376" page="" hidden="false" collective="false" import="true" type="upgrade">
      <comment>added in v1 by willus8888</comment>
      <profiles>
        <profile id="fa75-8cbe-6d97-d7f0" name="Outpost Machine-Guns" publicationId="afae-8f3f-0f99-8376" hidden="false" typeId="5cbd-556d-67b5-1bd9" typeName="Command Card">
          <comment>added in v1 by willus8888</comment>
          <characteristics>
            <characteristic name="Info" typeId="bd5c-655e-1889-6af7">With little hope of reinforcements, the thinly deployed line of the 28th Infantry Division was all that stood between the Germans and the vital crossroads of Bastogne</characteristic>
            <characteristic name="Details" typeId="4091-e11a-c858-f46e">M1919 LMG and M1917 HMG teams in this Unit cannot move, but can rotate to face the target when shooting, and are Nests.

Each LMG or HMG team is a seperate Independant Team.

Nests: The Nests are always Concealed and in Bulletproof Cover.

Teams attacking a nest must re-roll successful Firepower tests to Destroy it.

Nests cannot Charge into Contact, shoot at Aircraft, nor fire Bombardments</characteristic>
            <characteristic name="Notes" typeId="75a6-20ee-1c76-640a">US, Build, Unit (Infantry)</characteristic>
          </characteristics>
        </profile>
      </profiles>
      <categoryLinks>
        <categoryLink id="927e-eccd-e6d3-2db2" name="New CategoryLink" hidden="false" targetId="c5b6-63ee-3f81-25f2" primary="true"/>
      </categoryLinks>
      <costs>
        <cost name="pts" typeId="995a-4d67-6920-bfe4" value="2.0"/>
      </costs>
    </selectionEntry>
        <selectionEntry id="e256-64ed-e7e3-3c7d" name="Tank Destroyer Hyper-Velocity AP" publicationId="afae-8f3f-0f99-8376" page="" hidden="false" collective="false" import="true" type="upgrade">
      <comment>added in v1 by willus8888</comment>
      <profiles>
        <profile id="5fc9-9609-05e6-675f" name="Tank Destroyer Hyper-Velocity AP" publicationId="afae-8f3f-0f99-8376" hidden="false" typeId="5cbd-556d-67b5-1bd9" typeName="Command Card">
          <comment>added in v1 by willus8888</comment>
          <characteristics>
            <characteristic name="Info" typeId="bd5c-655e-1889-6af7">Hyper-velocity armour-piercing (HVAP) ammunition was issued to US tank and anti-tank units from late 1944. This anti-tank projectile has a core of a high-density hard tungsten carbide, surrounded by a shell of a lighter aluminium alloy. The kinectic energy of the round is concentrated in the heavier core into a smaller impact area, improving the round&apos;s armour penetration</characteristic>
            <characteristic name="Details" typeId="4091-e11a-c858-f46e">All Teams with 3-inch or 76mm guns increase their Anti-tank rating to 13 for +1 point per two teams (or part thereof)</characteristic>
            <characteristic name="Notes" typeId="75a6-20ee-1c76-640a">US, Build, Upgrade, Unit (M10 Tank Destroyer Platoon, M18 Tank Destroyer Platoon, 3-inch Tank Destroyer Platoon)</characteristic>
          </characteristics>
        </profile>
        <profile id="216e-672d-ec27-426f" name="M10 (3-inch) (HVAP)" publicationId="afae-8f3f-0f99-8376" page="" hidden="false" typeId="33b6-a72a-2bd8-2565" typeName="Weapon">
          <comment>added in v1 by willus8888</comment>
          <characteristics>
            <characteristic name="Range" typeId="c2e5-4990-8105-f793">36&quot;/90cm</characteristic>
            <characteristic name="Halted ROF" typeId="7f6e-6f8f-5f15-6e9d">2</characteristic>
            <characteristic name="Moving ROF" typeId="f78e-b583-b3a5-754a">1</characteristic>
            <characteristic name="Anti-Tank" typeId="f57e-fa10-d0f9-e2dd">13</characteristic>
            <characteristic name="Firepower" typeId="9cf3-a34f-60d9-1309">3+</characteristic>
            <characteristic name="Notes" typeId="d939-5084-e654-44c6">No HE</characteristic>
          </characteristics>
        </profile>
        <profile id="180e-6d7d-4439-54b6" name="M18 (76mm) (HVAP)" publicationId="afae-8f3f-0f99-8376" page="" hidden="false" typeId="33b6-a72a-2bd8-2565" typeName="Weapon">
          <comment>added in v1 by willus8888</comment>
          <characteristics>
            <characteristic name="Range" typeId="c2e5-4990-8105-f793">36&quot;/90cm</characteristic>
            <characteristic name="Halted ROF" typeId="7f6e-6f8f-5f15-6e9d">2</characteristic>
            <characteristic name="Moving ROF" typeId="f78e-b583-b3a5-754a">1</characteristic>
            <characteristic name="Anti-Tank" typeId="f57e-fa10-d0f9-e2dd">13</characteristic>
            <characteristic name="Firepower" typeId="9cf3-a34f-60d9-1309">3+</characteristic>
            <characteristic name="Notes" typeId="d939-5084-e654-44c6">No HE</characteristic>
          </characteristics>
        </profile>
        <profile id="96b2-e17b-07ea-5d39" name="3-inch gun (HVAP)" publicationId="afae-8f3f-0f99-8376" page="" hidden="false" typeId="33b6-a72a-2bd8-2565" typeName="Weapon">
          <comment>added in v1 by willus8888</comment>
          <characteristics>
            <characteristic name="Range" typeId="c2e5-4990-8105-f793">36&quot;/90cm</characteristic>
            <characteristic name="Halted ROF" typeId="7f6e-6f8f-5f15-6e9d">2</characteristic>
            <characteristic name="Moving ROF" typeId="f78e-b583-b3a5-754a">1</characteristic>
            <characteristic name="Anti-Tank" typeId="f57e-fa10-d0f9-e2dd">13</characteristic>
            <characteristic name="Firepower" typeId="9cf3-a34f-60d9-1309">3+</characteristic>
            <characteristic name="Notes" typeId="d939-5084-e654-44c6">Forward Firing, No HE</characteristic>
          </characteristics>
        </profile>
      </profiles>
      <categoryLinks>
        <categoryLink id="2b50-cf7b-473d-d2ee" name="New CategoryLink" hidden="false" targetId="c5b6-63ee-3f81-25f2" primary="true"/>
      </categoryLinks>
      <costs>
        <cost name="pts" typeId="995a-4d67-6920-bfe4" value="0.0"/>
      </costs>
    </selectionEntry>
        <selectionEntry id="2985-3b98-a384-4c10" name="LVT-4 Amtrac Transport" publicationId="afae-8f3f-0f99-8376" hidden="false" collective="false" import="true" type="upgrade">
      <comment>added in v1 by willus8888</comment>
      <profiles>
        <profile id="5a30-6688-7516-5fe7" name="LVT-4 Amtrac Transport" publicationId="afae-8f3f-0f99-8376" hidden="false" typeId="5cbd-556d-67b5-1bd9" typeName="Command Card">
          <comment>added in v1 by willus8888</comment>
          <characteristics>
            <characteristic name="Info" typeId="bd5c-655e-1889-6af7">For the Roer crossing operations, the 29th Infantry Division were provided LVT-4 Amtrac amphibious transports, which helped the 155th Regiments&apos;s assault troops to cross the river and establish a bridgehead</characteristic>
            <characteristic name="Details" typeId="4091-e11a-c858-f46e">This infantry Unit may add an LVT-4 Antrac Transport Attachment. Add one LVT-4 Amtrac Transport for each seven infantry teams in the Unit. The characteristics of an LVT-4 Amtrac Transport are shown here and on the back of this card</characteristic>
            <characteristic name="Notes" typeId="75a6-20ee-1c76-640a">US, Build, Unit (battle Weary Rifle Platoon)</characteristic>
          </characteristics>
        </profile>
        <profile id="34a3-7d84-0824-25bb" name="LVT-4 (MGs)" publicationId="afae-8f3f-0f99-8376" page="" hidden="false" typeId="33b6-a72a-2bd8-2565" typeName="Weapon">
          <comment>added in v1 by willus8888</comment>
          <characteristics>
            <characteristic name="Range" typeId="c2e5-4990-8105-f793">16&quot;/40cm</characteristic>
            <characteristic name="Halted ROF" typeId="7f6e-6f8f-5f15-6e9d">2</characteristic>
            <characteristic name="Moving ROF" typeId="f78e-b583-b3a5-754a">2</characteristic>
            <characteristic name="Anti-Tank" typeId="f57e-fa10-d0f9-e2dd">2</characteristic>
            <characteristic name="Firepower" typeId="9cf3-a34f-60d9-1309">6</characteristic>
            <characteristic name="Notes" typeId="d939-5084-e654-44c6"/>
          </characteristics>
        </profile>
        <profile id="6266-8b90-f23f-baab" name="LVT-4 (.50 cal MG)" publicationId="afae-8f3f-0f99-8376" page="" hidden="false" typeId="33b6-a72a-2bd8-2565" typeName="Weapon">
          <comment>added in v1 by willus8888</comment>
          <characteristics>
            <characteristic name="Range" typeId="c2e5-4990-8105-f793">20&quot;/50cm</characteristic>
            <characteristic name="Halted ROF" typeId="7f6e-6f8f-5f15-6e9d">3</characteristic>
            <characteristic name="Moving ROF" typeId="f78e-b583-b3a5-754a">2</characteristic>
            <characteristic name="Anti-Tank" typeId="f57e-fa10-d0f9-e2dd">4</characteristic>
            <characteristic name="Firepower" typeId="9cf3-a34f-60d9-1309">5+</characteristic>
            <characteristic name="Notes" typeId="d939-5084-e654-44c6">Self-defence AA</characteristic>
          </characteristics>
        </profile>
      </profiles>
      <categoryLinks>
