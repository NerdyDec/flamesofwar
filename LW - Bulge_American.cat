        <selectionEntry id="c684-aadd-7af6-4e5b" name="Richard Winters" publicationId="afae-8f3f-0f99-8376" page="" hidden="false" collective="false" import="true" type="unit">
      <comment>added in v1 by willus8888</comment>
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="73d6-1782-2f4e-9999" type="max"/>
      </constraints>
      <profiles>
        <profile id="0888-b650-4eaf-583e" name="Richard Winters" publicationId="afae-8f3f-0f99-8376" hidden="false" typeId="5cbd-556d-67b5-1bd9" typeName="Command Card">
          <comment>added in v1 by willus8888</comment>
          <characteristics>
            <characteristic name="Info" typeId="bd5c-655e-1889-6af7">During the Battle of the Bulge Winters kept a close connection with Easy Company.
When the hard missions came up he relied on Easy Company to get the job done. At Foy, for example. Winters carefully monitored Easy&apos;s assault and quickly replaced Dike with Speirs to press home the attack.</characteristic>
            <characteristic name="Details" typeId="4091-e11a-c858-f46e">Any Unit from this Formation whose Unit Leader is within 8&quot;/20cm and Line of Sight of this Formation Commander may re-roll failed Counterattack, Rally, Remount, and Last Stand rolls.</characteristic>
            <characteristic name="Notes" typeId="75a6-20ee-1c76-640a">US, Warrior, Formation (Bastogne Parachute Rifle Company)</characteristic>
          </characteristics>
        </profile>
      </profiles>
      <categoryLinks>
        <categoryLink id="58e7-452a-32b8-e4b4" name="New CategoryLink" hidden="false" targetId="c5b6-63ee-3f81-25f2" primary="true"/>
      </categoryLinks>
      <costs>
        <cost name="pts" typeId="995a-4d67-6920-bfe4" value="4.0"/>
      </costs>
    </selectionEntry>
