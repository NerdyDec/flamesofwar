      </characteristics>
    </profile>
  </profiles>
  <rules>
    <rule id="69d7-1a13-45fd-f854" name="Passengers 2, Tractor" hidden="false">
      <description>Team can carry two Infantry Teams or one Gun Team as Passengers.</description>
    </rule>
  </rules>
