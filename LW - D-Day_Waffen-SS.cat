  <profiles>
    <profile id="78da-8cbf-8575-5ace" name="1st &apos;Leibstandarte&apos; Street Fighters" typeId="5cbd-556d-67b5-1bd9" typeName="Command Card" hidden="false">
      <characteristics>
        <characteristic name="Details" typeId="4091-e11a-c858-f46e">The Formation Command team is rated asIS HIT ONCAREFUL4+If the Formation Command team is Destroyed, it can Switch to Another Team (see page 63 of the rulebook) on a roll of 2+ rather than 3+.</characteristic>
        <characteristic name="Notes" typeId="75a6-20ee-1c76-640a">German, Build, Formation, Title</characteristic>
