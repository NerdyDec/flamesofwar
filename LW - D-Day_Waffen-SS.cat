      <characteristics>
        <characteristic name="Details" typeId="fa11-60d9-4bb8-7538">The Formation Commander has a Halted ROF of 3, a Moving ROF of 2, and re-rolls all failed To Hit rolls when Shooting with its 8.8cm gun.The Formation HQ Unit may deploy using the Ambush special rule in addition to any other Units that would normally be held in Ambush, even in missions without the Ambush special rule.</characteristic>
      </characteristics>
    </profile>
    <profile id="ed97-d449-f095-3ce2" name="Forces ID" typeId="86a9-a6ee-b9bd-dafe" typeName="Forces ID" hidden="false">
