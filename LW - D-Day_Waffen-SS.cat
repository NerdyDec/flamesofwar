        <selectionEntry id="e067-21a3-6775-ae4d" name="Pakfront" hidden="true" collective="false" import="true" type="upgrade">
  <comment>GUN</comment>
  <constraints>
    <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="false" includeChildSelections="true" includeChildForces="false" id="e807-b305-1d15-7895" type="max"/>
