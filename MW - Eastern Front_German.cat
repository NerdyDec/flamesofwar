        <selectionEntry id="9a08-1257-4e8a-fad1" name="Pure Luck" hidden="false" collective="false" import="true" type="unit">
          <constraints>
            <constraint field="selections" scope="force" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="4956-1ec3-2bcf-82c3" type="max"/>
          </constraints>
          <profiles>
            <profile id="fd30-5485-4d53-bb38" name="Pure Luck" hidden="false" typeId="5cbd-556d-67b5-1bd9" typeName="Command Card">
              <characteristics>
                <characteristic name="Info" typeId="bd5c-655e-1889-6af7">Some men have all the luck.</characteristic>
                <characteristic name="Details" typeId="4091-e11a-c858-f46e">Discard this card to re-roll any one die. The second result must be used.</characteristic>
                <characteristic name="Notes" typeId="75a6-20ee-1c76-640a">German, Force, Limited</characteristic>
              </characteristics>
            </profile>
