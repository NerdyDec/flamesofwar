  <sharedSelectionEntries>
    <selectionEntry id="51da-85c1-85f1-e559" name="Lucky" hidden="false" collective="false" import="true" type="upgrade">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="f00c-d7a5-1acd-9856" type="max"/>
        <constraint field="selections" scope="force" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="2953-530d-ed3c-07c3" type="max"/>
      </constraints>
      <rules>
        <rule id="95dd-5571-8b05-1300" name="Lucky" hidden="false">
          <description>Discard this card to re-roll any one die. The second result must be used.</description>
        </rule>
      </rules>
      <costs>
        <cost name="pts" typeId="995a-4d67-6920-bfe4" value="1.0"/>
      </costs>
    </selectionEntry>
  </sharedSelectionEntries>
  <sharedRules>
    <rule id="78b1-e237-ee2b-1e00" name="Stabiliser" hidden="false">
      <description>Insted of having a reduced Moving ROF, weapons with Stabiliser suffer a +1 penalty to hit if the shooting Tank Moved in the Moving Step</description>
    </rule>
    <rule id="60ef-7630-74ab-101a" name="Blood&apos;n Guts" publicationId="b8e5-51cf-456c-eafb" hidden="false">
      <description>Tanks with Blood&apos;n Guts have better Last Stand ratings. Infantry and Guns with Blood&apos;n Guts have better Rally ratings.</description>
    </rule>
    <rule id="7e8c-744e-561a-30e4" name="Self-Defence AA" hidden="false">
      <description>Self-Defence AA weapons can Shoot at Aircraft with ROF 1.</description>
    </rule>
    <rule id="ed5c-96d9-16d8-cf48" name="SP Gun" hidden="false">
      <description>SP Guns have a worse Counterattack rating and a worse Assault rating. If they are Open-topped they have a significantly worse Counterattack rating.</description>
    </rule>
    <rule id="eb5e-87d5-70ae-4ac8" name="No HE" hidden="false">
      <description>A weapon with No HE targeting an Infantry or Gun Team, adds +1 to the score needed To Hit.</description>
    </rule>
    <rule id="25ee-b422-d6d4-4724" name="Smoke" hidden="false">
      <description>Smoke weapons can Shoot Smoke ammunition.</description>
    </rule>
    <rule id="3429-7809-1ab5-ae20" name="Seek, Strike and Destroy" hidden="false">
      <description>A Unit with Seek, Strike and Destroy my attempt a Shoot and Scoot Movement Order after succeeding with a Blitz Move Movment Order earlier in the same turn.</description>
    </rule>
    <rule id="0a6f-4121-7f8b-379a" name="Overworked" hidden="false">
      <description>Overworked weapons add +1 to the scort To Hit when moving.</description>
    </rule>
    <rule id="5c99-643c-d213-1d57" name="Scout" hidden="false">
      <description>Scouts are Gone to Ground unless they Shoot or Assault. This means that if they are Conseald, they enemy will suffer an additional +1 penelty to hit them.

Scouts have a worse Last Stand rating, Open or Wheeled Scout tanks have a significantly worse Counterattack rating and a worse Assault rating as well.</description>
    </rule>
    <rule id="2542-0790-1e9a-ee39" name="Spearhead" hidden="false"/>
    <rule id="876b-6bbf-bfd7-1d56" name="Component" hidden="false">
      <description>Component Teams rule use the same rating of their parent Unit.</description>
    </rule>
    <rule id="40a1-303d-123b-db1b" name="Forward Firing" hidden="false"/>
    <rule id="deb9-3ceb-8253-2709" name="Smoke Bombardment" hidden="false"/>
    <rule id="fddd-5c21-d7c0-e9f2" name="Rear Firing" hidden="false"/>
    <rule id="d787-4efa-b655-68ac" name="HQ Transport" hidden="false"/>
    <rule id="81fb-31c7-ad6c-9ba0" name="Observer" hidden="false">
      <description>The Unit Leader of a Unit with Observer can spot for any friendly Artilery Unit.</description>
    </rule>
    <rule id="c5c7-ac19-160e-ad24" name="Heavy Weapon" hidden="false">
      <description>A Heavy Weapon Team cannot Charge into Contact, but may be an Assaulting Team if in Contact with an enemy Team. Heavy Weapons have a worse Assault rating.</description>
    </rule>
    <rule id="0583-a56d-f6d9-c978" name="Assault 5+" hidden="false">
      <description>Teams with the Assault # special rule uses # number for To Hit rolls in Assaults rather than the normal one shown on the card.</description>
    </rule>
    <rule id="552e-5ee0-a7cf-5f51" name="Slow Firing" hidden="false"/>
    <rule id="809b-68c1-46c9-396a" name="Pinned ROF 1" hidden="false"/>
    <rule id="1e73-961d-c3a2-1e89" name="Gun Shield" hidden="false">
      <description>A Gun Team with the Gun Shield is in Bulletproof Cover when Shot at from in front of the Team&apos;s base. A Gun Shield does not offer any protection against Artillery Bombardments or if the Team moved at Dash speed.</description>
    </rule>
    <rule id="31bc-16fd-4fce-e39f" name="Gun" hidden="false"/>
    <rule id="84bd-3f9e-77ac-df39" name="Large Gun" hidden="false"/>
    <rule id="ebad-f3a0-0af8-2e05" name="Time on Target" hidden="false">
      <description>If an Artillery Unit with Time on Targer ranges in on the first attempt, any Infantry or Gun Teams hit by the Bombardment must re-roll successful Saves.</description>
    </rule>
    <rule id="cef6-0612-5d3c-7f62" name="Independent Tank Unit" hidden="false"/>
    <rule id="0143-527a-798f-4b5b" name="Brutal" hidden="false"/>
    <rule id="6545-ef87-e687-18df" name="Dedicated AA" hidden="false"/>
    <rule id="0d91-6c09-5015-b949" name="MG Transport" hidden="false">
      <description>M1917 HMG or M1919 LMG teams my fire while Monunted as a Passenger in an M3 half-track, using the Optional Passenger MG weapon line.	</description>
    </rule>
    <rule id="3aa5-5551-d5ff-d180" name="Combat Engineer" hidden="false">
      <description>Infantry Teams in this Formation cross Minefields safely on a roll of 3+.
Indantry Units in this Formatiopn Dig In on a roll of 3+.</description>
    </rule>
  </sharedRules>
