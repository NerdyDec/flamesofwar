</selectionEntry><selectionEntry id="c9b6-4789-768a-60e6" name="265th Infantry Division Russian Guns" hidden="false" collective="false" import="true" type="upgrade">
  <profiles>
    <profile id="a561-8b52-a283-fcea" name="265th Infantry Division Russian Guns" typeId="5cbd-556d-67b5-1bd9" typeName="Command Card" hidden="false">
      <characteristics>
        <characteristic name="Details" typeId="4091-e11a-c858-f46e">This Force must field 76mm Artillery or 122mm Artillery Batteries (LS148 or LS149) (at the cost shown on the card) in place of 10.5cm Artillery Batteries, with the following ratings:
MOTIVATIONCONFIDENT4+Family MenLast Stand 5+
