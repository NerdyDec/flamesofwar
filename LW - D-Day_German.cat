</selectionEntry><selectionEntry id="6926-104a-a577-1469" name="Dug-In Panzer IV Platoon" hidden="false" collective="false" import="true" type="upgrade">
  <profiles>
    <profile id="af55-4ef1-013b-2134" name="Dug-In Panzer IV Platoon" typeId="5cbd-556d-67b5-1bd9" typeName="Command Card" hidden="false">
      <characteristics>
        <characteristic name="Details" typeId="4091-e11a-c858-f46e">Panzer IV tanks in this Unit are Concealed and cannot Move, but can rotate its turret to face the target when Shooting.Treat all Hits on these tanks as being on their turret when determining whether to use Front or Side armour.If placed from Ambush, they must be more than 16”/40cm from all enemy Teams within Line of Sight.</characteristic>
        <characteristic name="Notes" typeId="75a6-20ee-1c76-640a">German, Build, Unit (Panzer IV Tank Platoon), Limited</characteristic>
      </characteristics>
    </profile>
    <profile id="e931-9346-8fdc-4251" name="Forces ID" typeId="86a9-a6ee-b9bd-dafe" typeName="Forces ID" hidden="false">
      <characteristics>
