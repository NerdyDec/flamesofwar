  <profiles>
    <profile id="8fe1-11f6-a37a-bc6f" name="Panzer Pioneer Platoon" typeId="5cbd-556d-67b5-1bd9" typeName="Command Card" hidden="false">
      <characteristics>
        <characteristic name="Details" typeId="4091-e11a-c858-f46e">Infantry Teams in this Unit cross Minefields safely on a roll of 2+.This Unit Digs In on a roll of 2+.</characteristic>
        <characteristic name="Notes" typeId="75a6-20ee-1c76-640a">German, Build, Unit (Armoured Panzergrenadier Platoon, Panzergrenadier Platoon)</characteristic>
      </characteristics>
