        <selectionEntry id="f837-f497-2dcd-6c0" name="Night Attacks, 2nd Panzer Division" hidden="false" collective="false" import="true" type="upgrade">
      <profiles>
        <profile id="d57b-6ae2-9d08-c805" name="Night Attacks, 2nd Panzer Division" hidden="false" typeId="5cbd-556d-67b5-1bd9" typeName="Command Card">
          <characteristics>
            <characteristic name="Info" typeId="bd5c-655e-1889-6af7">On D-Day, the 2nd &apos;Vienna&apos; Panzer Division was the best equipped and trained division in the entire German Army. Faced with overwhelming firepower, they quickly learned that night operations were more survivable.</characteristic>
            <characteristic name="Details" typeId="4091-e11a-c858-f46e">If this Force is the attacker in a mission where the defender has Minefields, you may attack at night. If you do so, Night Fighting rules (see page 113 of the rulebook) are in effect at the start of the game.
Units from this Formation can move freely from the start of the game. Friendly Units from other Formations or Support may not move out of their Deployment Area until morning breaks.</characteristic>
            <characteristic name="Notes" typeId="75a6-20ee-1c76-640a">German, Build, Formation (Panzergrenadier Company), Title</characteristic>
          </characteristics>
        </profile>
      </profiles>
      <costs>
        <cost name="pts" typeId="995a-4d67-6920-bfe4" value="1.0"/>
      </costs>
    </selectionEntry>
        <selectionEntry id="9e60-6230-eeea-1429" name="Rebuilding, 9th Panzer Division" hidden="false" collective="false" import="true" type="upgrade">
      <profiles>
        <profile id="3d6d-e574-8e66-10f4" name="Rebuilding, 9th Panzer Division" hidden="false" typeId="5cbd-556d-67b5-1bd9" typeName="Command Card">
          <characteristics>
            <characteristic name="Info" typeId="bd5c-655e-1889-6af7">The remnants of the 9th Panzer Division had been fighting in Southern Russia just a month before D-Day. With little time to rebuild, and none to train the soldiers replacing the veterans lost on the Eastern Front, they were thrown back into battle.</characteristic>
            <characteristic name="Details" typeId="4091-e11a-c858-f46e">All Units in this Formation have a Tactics rating of 4+ for -1 point per Unit.
Skill: Tactics 4+</characteristic>
            <characteristic name="Notes" typeId="75a6-20ee-1c76-640a">German, Build, Formation (any Tank or Panzergrenadier Company), Title</characteristic>
          </characteristics>
        </profile>
      </profiles>
      <costs>
        <cost name="pts" typeId="995a-4d67-6920-bfe4" value="0.0"/>
      </costs>
    </selectionEntry>
        <selectionEntry id="c8b4-cf-7778-3def" name="Greyhound, 116th Panzer Division" hidden="false" collective="false" import="true" type="upgrade">
      <profiles>
        <profile id="427-2c01-63c0-6b89" name="Greyhound, 116th Panzer Division" hidden="false" typeId="5cbd-556d-67b5-1bd9" typeName="Command Card">
          <characteristics>
            <characteristic name="Info" typeId="bd5c-655e-1889-6af7">Ordered to counterattack the American breakthrough at Mortain, the newly-rebuilt 116th Panzer Division performed well as the rearguard at Falaise.</characteristic>
            <characteristic name="Details" typeId="4091-e11a-c858-f46e">All Units in this Formation lose Third Reich, and have a Last Stand rating of 5+ and a Tactics rating of 4+ for -1 points per Unit. (LFTF)
Motivation: Last Stand 5+
Skill: Tactics 4+</characteristic>
            <characteristic name="Notes" typeId="75a6-20ee-1c76-640a">German, Build, Formation (any Tank or Panzergrenadier Company), Title</characteristic>
          </characteristics>
        </profile>
      </profiles>
      <costs>
        <cost name="pts" typeId="995a-4d67-6920-bfe4" value="0.0"/>
      </costs>
    </selectionEntry>
        <selectionEntry id="2bed-8bf9-bdad-7173" name="Air Force Soldiers, 16th Luftwaffe Field Division" hidden="false" collective="false" import="true" type="upgrade">
      <profiles>
        <profile id="840-5730-d73b-3d7e" name="Air Force Soldiers, 16th Luftwaffe Field Division" hidden="false" typeId="5cbd-556d-67b5-1bd9" typeName="Command Card">
          <characteristics>
            <characteristic name="Info" typeId="bd5c-655e-1889-6af7">In 1942, the Luftwaffe (the German Air Force) formed 20 weak infantry divisions from unneeded ground crew. They were politically motivated, but they lacked infantry training, although their high level of education allowed them to pick up tricks quickly.</characteristic>
            <characteristic name="Details" typeId="4091-e11a-c858-f46e">The HQ Unit and all Beach Defence Grenadier Platoons in this Formation have the following ratings for +1 point per Unit:
Motivation: 4+, Counterattack 3+, Last Stand 5+
Skill: 5+, Tactics 4+</characteristic>
            <characteristic name="Notes" typeId="75a6-20ee-1c76-640a">German, Build, Formation (Beach Defence Grenadier Company), Title</characteristic>
          </characteristics>
        </profile>
      </profiles>
      <costs>
        <cost name="pts" typeId="995a-4d67-6920-bfe4" value="0.0"/>
      </costs>
    </selectionEntry>
        <selectionEntry id="3c27-9db1-676f-b827" name="Eastern Front, 352nd Infantry Division" hidden="false" collective="false" import="true" type="upgrade">
      <profiles>
        <profile id="b4e-b3f3-f483-68c" name="Eastern Front, 352nd Infantry Division" hidden="false" typeId="5cbd-556d-67b5-1bd9" typeName="Command Card">
          <characteristics>
            <characteristic name="Info" typeId="bd5c-655e-1889-6af7">The 352nd Infantry Division was formed from the devastated remains of the 321st Infantry Divisions which was destroyed defending Bryansk after the Battle of Kursk. Led by a handful of &apos;Front Swine&apos; who had learned their trade in the mud of the Eastern Front, they fought hard to hold what they had.</characteristic>
            <characteristic name="Details" typeId="4091-e11a-c858-f46e">The HQ Unit and all Beach Defence Grenadier Platoons in this Formation have the following ratings for +1 point per Unit:
Motivation: 4+, Last Stand 5+, Rally 3+
Skill: 5+, Assault 4+</characteristic>
            <characteristic name="Notes" typeId="75a6-20ee-1c76-640a">German, Build, Formation (Beach Defence Grenadier Company), Title</characteristic>
          </characteristics>
        </profile>
      </profiles>
      <costs>
        <cost name="pts" typeId="995a-4d67-6920-bfe4" value="0.0"/>
      </costs>
    </selectionEntry>
        <selectionEntry id="3840-5926-b300-dcf" name="Bicycles, 30th Fast Brigade" hidden="false" collective="false" import="true" type="upgrade">
      <profiles>
        <profile id="c448-1919-e78c-239c" name="Bicycles, 30th Fast Brigade" hidden="false" typeId="5cbd-556d-67b5-1bd9" typeName="Command Card">
          <characteristics>
            <characteristic name="Info" typeId="bd5c-655e-1889-6af7">The 30th Fast Brigade was the Seventh Army&apos;s mobile reserve. Mounted on bicycles and close behind the front, they were able to quickly reinforce the 352nd Infantry Division where they were desperately needed.</characteristic>
            <characteristic name="Details" typeId="4091-e11a-c858-f46e">Discard this card after rolling for Reserves to re-roll all of your Reserve rolls.
All Reserves arriving this turn must be from this Beach Defence Grenadier Company.</characteristic>
            <characteristic name="Notes" typeId="75a6-20ee-1c76-640a">German, Build, Formation (Beach Defence Grenadier Company), Title</characteristic>
          </characteristics>
        </profile>
      </profiles>
      <costs>
        <cost name="pts" typeId="995a-4d67-6920-bfe4" value="1.0"/>
      </costs>
    </selectionEntry>
        <selectionEntry id="d18c-11c-214c-274f" name="Assault Battalion, Seventh Army" hidden="false" collective="false" import="true" type="upgrade">
      <profiles>
        <profile id="72c1-12da-d849-10ad" name="Assault Battalion, Seventh Army" hidden="false" typeId="5cbd-556d-67b5-1bd9" typeName="Command Card">
          <characteristics>
            <characteristic name="Info" typeId="bd5c-655e-1889-6af7">Major Messerschmidt&apos;s assault battalion counter attacked the American airborne landings at Saint-Mere-Eglise, then fought its way back to defend the port of Cherbourg.</characteristic>
            <characteristic name="Details" typeId="4091-e11a-c858-f46e">The HQ Unit and all Beach Defence Grenadier Platoons in this Formation have the following ratings for +2 points per Unit:
Motivation: 4+
Skill: 4+, Assault 3+</characteristic>
            <characteristic name="Notes" typeId="75a6-20ee-1c76-640a">German, Build, Formation (Beach Defence Grenadier Company), Title</characteristic>
          </characteristics>
        </profile>
      </profiles>
      <costs>
        <cost name="pts" typeId="995a-4d67-6920-bfe4" value="0.0"/>
      </costs>
    </selectionEntry>
        <selectionEntry id="65f5-5df1-d954-2de7" name="Ost Battalion, 716th Infantry Division" hidden="false" collective="false" import="true" type="upgrade">
      <profiles>
        <profile id="9016-6a35-f42e-4b95" name="Ost Battalion, 716th Infantry Division" hidden="false" typeId="5cbd-556d-67b5-1bd9" typeName="Command Card">
          <characteristics>
            <characteristic name="Info" typeId="bd5c-655e-1889-6af7">Desperately short of soldiers, the German Army recruited Osttruppen from prisoners of war captured on the Eastern Front (Ostfront). While potentially unreliable, they freed up troops for more important tasks than guarding potential invasion beaches.</characteristic>
            <characteristic name="Details" typeId="4091-e11a-c858-f46e">All Beach Defence Grenadier Platoons in this Formation have the following ratings:
Motivation: 5+
Skill: 5+</characteristic>
            <characteristic name="Notes" typeId="75a6-20ee-1c76-640a">German, Build, Formation (Beach Defence Grenadier Company), Title</characteristic>
          </characteristics>
        </profile>
      </profiles>
      <costs>
        <cost name="pts" typeId="995a-4d67-6920-bfe4" value="-1.0"/>
      </costs>
    </selectionEntry>
        <selectionEntry id="d62f-596b-4738-148d" name="Defence of Brest, 2nd Fallschirmjäger Division" hidden="false" collective="false" import="true" type="upgrade">
      <profiles>
        <profile id="67eb-2555-fb11-c1c2" name="Defence of Brest, 2nd Fallschirmjäger Division" hidden="false" typeId="5cbd-556d-67b5-1bd9" typeName="Command Card">
          <characteristics>
            <characteristic name="Info" typeId="bd5c-655e-1889-6af7">The veteran 2nd Fallschirmjäger Division had suffered badly as it attempted to halt the Red Army&apos;s advance across the Ukraine. It had barely arrived in Germany for rebuilding when it was sent to hold the port of Brest along with a motley assortment of second line troops. The division&apos;s aggressive raids kept the besieging American forces at bay.</characteristic>
            <characteristic name="Details" typeId="4091-e11a-c858-f46e">Replace one Fallschirmjäger Platoon in this Formation with a Beach Defence Grenadier Platoon.
Fallschirmjäger Platoons in this Formation have the Spearhead rule, but only Fallschirmjäger Units may deploy in the Spearhead extension to their Deployment Area.</characteristic>
            <characteristic name="Notes" typeId="75a6-20ee-1c76-640a">German, Build, Formation (Fallschirmjäger Company), Title</characteristic>
          </characteristics>
        </profile>
      </profiles>
      <costs>
        <cost name="pts" typeId="995a-4d67-6920-bfe4" value="2.0"/>
      </costs>
    </selectionEntry>
        <selectionEntry id="21a7-2a82-4c4-80ac" name="No Jump Training, 5th Fallschirmjäger Division" hidden="false" collective="false" import="true" type="upgrade">
      <profiles>
        <profile id="8614-9653-ec91-b175" name="No Jump Training, 5th Fallschirmjäger Division" hidden="false" typeId="5cbd-556d-67b5-1bd9" typeName="Command Card">
          <characteristics>
            <characteristic name="Info" typeId="bd5c-655e-1889-6af7">Only one-in-ten of the 5th Fallschirmjäger Division had completed jump training, and many of their ex-Air Force officers had no infantry training, by the time they were sent into battle. Despite this, they fought bravely.</characteristic>
            <characteristic name="Details" typeId="4091-e11a-c858-f46e">The HQ and all Fallschirmjäger Rifle Platoons in this Formation have the following ratings for -1 point per Unit:
Motivation: 3+
Skill: 4+</characteristic>
            <characteristic name="Notes" typeId="75a6-20ee-1c76-640a">German, Build, Formation (Fallschirmjäger Company), Title</characteristic>
          </characteristics>
        </profile>
      </profiles>
      <costs>
        <cost name="pts" typeId="995a-4d67-6920-bfe4" value="0.0"/>
      </costs>
    </selectionEntry>
        <selectionEntry id="32fa-6f1-c81-93b0" name="Von Der Heydte, 6th Fallschirmjäger Regiment" hidden="false" collective="false" import="true" type="upgrade">
      <profiles>
        <profile id="d7e3-2650-535d-13c5" name="Von Der Heydte, 6th Fallschirmjäger Regiment" hidden="false" typeId="5cbd-556d-67b5-1bd9" typeName="Command Card">
          <characteristics>
            <characteristic name="Info" typeId="bd5c-655e-1889-6af7">Major Friedrich von der Heydte&apos;s 6th Fallschirmjäger Regiment was in action against American paratroopers on D-Day and fought until the end of the campaign, surviving despite being trapped in two pockets.</characteristic>
            <characteristic name="Details" typeId="4091-e11a-c858-f46e">Any Unit from this Fallschirmjäger Company whose Unit Leader is within 6&quot;/15cm of the Formation Commander has a Last Stand rating of 2+.</characteristic>
            <characteristic name="Notes" typeId="75a6-20ee-1c76-640a">German, Build, Formation (Fallschirmjäger Company), Title</characteristic>
          </characteristics>
        </profile>
      </profiles>
      <costs>
        <cost name="pts" typeId="995a-4d67-6920-bfe4" value="0.0"/>
      </costs>
    </selectionEntry>
        <selectionEntry id="9165-4394-aea5-6cc" name="10.5cm Howitzer, 275th Infantry Division" hidden="false" collective="false" import="true" type="upgrade">
      <profiles>
        <profile id="2a4b-5b4b-55ca-861f" name="10.5cm Howitzer, 275th Infantry Division" hidden="false" typeId="5cbd-556d-67b5-1bd9" typeName="Command Card">
          <characteristics>
            <characteristic name="Info" typeId="bd5c-655e-1889-6af7">Some of the infantry divisions in Normandy had been hastily formed, and lacked the desired level of training and experience.</characteristic>
            <characteristic name="Details" typeId="4091-e11a-c858-f46e">All 10.5cm Artillery Batteries in this Force have the following ratings for -1 point per Gun team:
Motivation: 4+, Last Stand 5+
Skill: 4+, Assault 6
Is Hit On: 3+</characteristic>
            <characteristic name="Notes" typeId="75a6-20ee-1c76-640a">German, Build, Formation (Beach Defence Grenadier Company), Title</characteristic>
          </characteristics>
        </profile>
      </profiles>
      <costs>
        <cost name="pts" typeId="995a-4d67-6920-bfe4" value="0.0"/>
      </costs>
    </selectionEntry>
        <selectionEntry id="1b3f-c681-2b57-722" name="8.8cm Tank-Hunter, 77th Infantry Division" hidden="false" collective="false" import="true" type="upgrade">
      <profiles>
        <profile id="ea54-fb2a-77a8-15c8" name="8.8cm Tank-Hunter, 77th Infantry Division" hidden="false" typeId="5cbd-556d-67b5-1bd9" typeName="Command Card">
          <characteristics>
            <characteristic name="Info" typeId="bd5c-655e-1889-6af7">Despite its hasty raising and general shortage of equipment, the artillery regiment of the 77th Infantry Division included a battalion of powerful 8.8cm anti-tank guns.</characteristic>
            <characteristic name="Details" typeId="4091-e11a-c858-f46e">All 8.8cm Tank-hunter Platoons in this Force have the following ratings for -1 point per Gun team:
Motivation: 4+, Last Stand 5+
Skill: 4+, Assault 6
Is Hit On: 3+</characteristic>
            <characteristic name="Notes" typeId="75a6-20ee-1c76-640a">German, Build, Formation (Beach Defence Grenadier Company), Title</characteristic>
          </characteristics>
        </profile>
      </profiles>
      <costs>
        <cost name="pts" typeId="995a-4d67-6920-bfe4" value="0.0"/>
      </costs>
    </selectionEntry>
        <selectionEntry id="7d92-4fd9-d729-397c" name="Russian Guns, 265th Infantry Division" hidden="false" collective="false" import="true" type="upgrade">
      <profiles>
        <profile id="bd09-63eb-41cf-3e93" name="Russian Guns, 265th Infantry Division" hidden="false" typeId="5cbd-556d-67b5-1bd9" typeName="Command Card">
          <characteristics>
            <characteristic name="Info" typeId="bd5c-655e-1889-6af7">The shortage of German equipment meant that formations like the 265th Infantry Division had to make do with captured Russian guns.</characteristic>
            <characteristic name="Details" typeId="4091-e11a-c858-f46e">This Force must field 76mm Artillery or 122mm Artillery Batteries (LS148 or LS149) (at the cost shown on the card) in place of 10.5cm Artillery Batteries, with the following ratings:
Motivation: 4+, Last Stand 5+
Skill: 4+, Assault 6
Is Hit On: 3+</characteristic>
            <characteristic name="Notes" typeId="75a6-20ee-1c76-640a">German, Build, Formation (Beach Defence Grenadier Company), Title</characteristic>
          </characteristics>
        </profile>
      </profiles>
      <costs>
        <cost name="pts" typeId="995a-4d67-6920-bfe4" value="0.0"/>
      </costs>
    </selectionEntry>
        <selectionEntry id="de43-ab6c-c814-2a5d" name="Softskin Transport" hidden="false" collective="false" import="true" type="upgrade">
  <profiles>
    <profile id="f6f5-2ba3-185b-b6ba" name="Softskin Transport" hidden="false" typeId="5cbd-556d-67b5-1bd9" typeName="Command Card">
      <characteristics>
        <characteristic name="Info" typeId="bd5c-655e-1889-6af7">The divisions training in France had a low priority for trucks and other transport, while the costal defence divisions had almost none! Despite this, some units managed to scrape together enough vehicles to motorise at least part of their guns and infantry.</characteristic>
        <characteristic name="Details" typeId="4091-e11a-c858-f46e">This Infantry or Gun Unit may add a Softskin Transport Attachment. The number of vehicles in the Unit is as follows:Add one Softskin Transport for every two Infantry Teams in the Unit.Add one Softskin Transport for each Gun Team in the Unit.
MOTIVATIONCONFIDENT4+
SKILLVETERAN3+
IS HIT ONCAREFUL4+
SAVETANK5+
TACTICALTERRAIN DASHCROSS COUNTRY DASHROAD DASHCROSS-10&quot;/25cm18&quot;/45cm40&quot;/100cm4+SPECIAL RULESPassengers 2, Tractor: Team can carry two Infantry Teams or one Gun Team as Passengers.Softskin: If a Transport is Destroyed, any Passengers it is carrying are also Destroyed, and all Transports must be Sent to the Rear immediately. All Passengers must Dismount from this Unit at the same time. Empty Transport Teams must be Sent to the Rear.Unarmoured: Team cannot Charge into Contact and must Break Off if Assaulted.</characteristic>
        <characteristic name="Notes" typeId="75a6-20ee-1c76-640a">German, Build, Unit (Infantry or Gun)</characteristic>
      </characteristics>
    </profile>
    <profile id="454c-b18d-782-e77f" name="Softskin Transport" hidden="false" typeId="7cf5-5c36-14cc-3c0d" typeName="Unarmoured Tank Unit">
      <characteristics>
        <characteristic name="Motivation" typeId="55ef-8653-887d-4642">4+</characteristic>
        <characteristic name="Skill" typeId="229c-c44f-2910-c1d1">3+</characteristic>
        <characteristic name="Is Hit On" typeId="acbb-3bc2-c667-6e4d">4+</characteristic>
        <characteristic name="Save" typeId="6e6b-7d9e-7557-43cd">5+</characteristic>
        <characteristic name="Tactical" typeId="6caa-857a-dce7-e965">-</characteristic>
        <characteristic name="Terrain Dash" typeId="f188-5e37-f014-5069">10”/25cm</characteristic>
        <characteristic name="Cross Country Dash" typeId="d2da-b73b-7a4a-ca53">18”/45cm</characteristic>
        <characteristic name="Road Dash" typeId="271f-e64c-128c-5740">40&quot;/100cm</characteristic>
        <characteristic name="Cross" typeId="b443-5f9e-d0b5-48b0">4+</characteristic>
        <characteristic name="Notes" typeId="5c4c-b4d7-c2d1-6a93">Passengers 2, Softskin, Tractor</characteristic>
      </characteristics>
    </profile>
    <profile id="a86b-003c-0045-4f81" name="Forces ID" typeId="86a9-a6ee-b9bd-dafe" typeName="Forces ID" hidden="false">
      <characteristics>
        <characteristic name="ID" typeId="846f-94be-be15-4936">70bf7ae9-da41-5389-b347-e1f9a65d06a8</characteristic>
      </characteristics>
    </profile>
  </profiles>
  <infoLinks>
    <infoLink id="daa7-5879-39c2-34e3" name="Passengers 2" hidden="false" targetId="23e1-f5f2-1523-0d4c" type="rule"/>
    <infoLink id="79aa-a41b-611b-5c44" name="Tractor" hidden="false" targetId="1add-f696-3ad3-0243" type="rule"/>
    <infoLink id="db08-e0d8-3f68-a9f4" name="Softskin" hidden="false" targetId="c72e-a283-4a87-3078" type="rule"/>
    <infoLink id="1809-65b4-450f-c4c1" name="Unarmoured" hidden="false" targetId="a5c7-5baa-4aad-ed13" type="rule"/>
  </infoLinks>
  <costs>
    <cost name="pts" typeId="995a-4d67-6920-bfe4" value="1.0"/>
  </costs>
</selectionEntry><selectionEntry id="c5db-d4a3-b881-13ad" name="Sd Kfz 250 OP" hidden="false" collective="false" import="true" type="upgrade">
  <profiles>
    <profile id="3f68-634b-6c8f-dfac" name="Sd Kfz 250 OP" typeId="5cbd-556d-67b5-1bd9" typeName="Command Card" hidden="false">
      <characteristics>
        <characteristic name="Details" typeId="4091-e11a-c858-f46e">Replace the Panzer III OP with an Sd Kfz 250 OP</characteristic>
        <characteristic name="Notes" typeId="75a6-20ee-1c76-640a">German, Build, Unit (Panzer III OP)</characteristic>
      </characteristics>
    </profile>
    <profile id="6fca-ad86-5777-a215" name="Forces ID" typeId="86a9-a6ee-b9bd-dafe" typeName="Forces ID" hidden="false">
      <characteristics>
        <characteristic name="ID" typeId="846f-94be-be15-4936">7bfe4261-42d5-54b4-acf6-98e1511a698b</characteristic>
      </characteristics>
    </profile>
  </profiles>
  <costs>
    <cost name="pts" typeId="995a-4d67-6920-bfe4" value="0.0"/>
  </costs>
  <categoryLinks>
    <categoryLink id="1b32-baba-73bd-337a" name="Command Cards" hidden="false" targetId="c5b6-63ee-3f81-25f2" primary="true"/>
  </categoryLinks>
</selectionEntry><selectionEntry id="9c5e-53de-8f40-0fd7" name="Lucky" hidden="false" collective="false" import="true" type="upgrade">
  <profiles>
    <profile id="92a9-a232-de8b-8418" name="Lucky" typeId="5cbd-556d-67b5-1bd9" typeName="Command Card" hidden="false">
      <characteristics>
        <characteristic name="Details" typeId="4091-e11a-c858-f46e">Discard this card to re-roll any one die. The second result must be used.</characteristic>
        <characteristic name="Notes" typeId="75a6-20ee-1c76-640a">German, Force, Limited</characteristic>
      </characteristics>
    </profile>
    <profile id="bf36-24a2-8522-7b67" name="Forces ID" typeId="86a9-a6ee-b9bd-dafe" typeName="Forces ID" hidden="false">
      <characteristics>
        <characteristic name="ID" typeId="846f-94be-be15-4936">603a58ad-4fb5-510a-a819-824f37e2efff</characteristic>
      </characteristics>
    </profile>
  </profiles>
  <costs>
    <cost name="pts" typeId="995a-4d67-6920-bfe4" value="1.0"/>
  </costs>
  <categoryLinks>
    <categoryLink id="0ec6-eb9c-542d-33f0" name="Command Cards" hidden="false" targetId="c5b6-63ee-3f81-25f2" primary="true"/>
  </categoryLinks>
</selectionEntry><selectionEntry id="016e-52d1-670c-c6af" name="Assault Gun Escorts" hidden="false" collective="false" import="true" type="upgrade">
  <profiles>
    <profile id="ac1a-9e21-6dc6-b4bb" name="Assault Gun Escorts" typeId="5cbd-556d-67b5-1bd9" typeName="Command Card" hidden="false">
      <characteristics>
        <characteristic name="Details" typeId="4091-e11a-c858-f46e">Infantry teams from the Fallschirmjäger Rifle Platoon or Beach Defence Grenadier Platoon from within this Formation can Shoot while Mounted on Armoured Tank teams from this Formation (to a maximum of one team per Tank), and can Dismount when Charging into Contact.</characteristic>
        <characteristic name="Notes" typeId="75a6-20ee-1c76-640a">German, Build, Formation (Fallschirmjäger StuG Assault Gun Company)</characteristic>
      </characteristics>
    </profile>
    <profile id="9891-b73a-1c29-c298" name="Forces ID" typeId="86a9-a6ee-b9bd-dafe" typeName="Forces ID" hidden="false">
      <characteristics>
        <characteristic name="ID" typeId="846f-94be-be15-4936">4cb102d7-c436-5af6-89b7-0b32cb66151f</characteristic>
      </characteristics>
    </profile>
  </profiles>
  <costs>
    <cost name="pts" typeId="995a-4d67-6920-bfe4" value="1.0"/>
  </costs>
  <categoryLinks>
    <categoryLink id="5b1d-1991-aaad-0f23" name="Command Cards" hidden="false" targetId="c5b6-63ee-3f81-25f2" primary="true"/>
  </categoryLinks>
</selectionEntry><selectionEntry id="ebbd-02bf-abb3-1ff3" name="Pioneer Platoon" hidden="false" collective="false" import="true" type="upgrade">
  <profiles>
    <profile id="b25d-7d92-8dd4-33df" name="Pioneer Platoon" typeId="5cbd-556d-67b5-1bd9" typeName="Command Card" hidden="false">
      <characteristics>
        <characteristic name="Details" typeId="4091-e11a-c858-f46e">Infantry Teams in this Unit cross Minefields safely on a roll of 3+.This Unit Digs In on a roll of 3+.</characteristic>
        <characteristic name="Notes" typeId="75a6-20ee-1c76-640a">German, Build, Unit (Beach Defence Grenadier Platoon)</characteristic>
      </characteristics>
    </profile>
