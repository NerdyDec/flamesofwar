</selectionEntry><selectionEntry id="7f6a-86e5-9429-b759" name="Kurt Knispel" hidden="false" collective="false" import="true" type="upgrade">
  <profiles>
    <profile id="ad86-bdba-da0d-db57" name="Kurt Knispel" typeId="5cbd-556d-67b5-1bd9" typeName="Command Card" hidden="false">
      <characteristics>
        <characteristic name="Details" typeId="4091-e11a-c858-f46e">The Unit Leadter may re-roll all failed rolls To Hit each time he Shoots with his 8.8cm gun.This Unit automatically passes all Last Stand tests.</characteristic>
        <characteristic name="Notes" typeId="75a6-20ee-1c76-640a">German, Unit, Warrior (Tiger Tank Platoon)</characteristic>
