</selectionEntry><selectionEntry id="63dc-af61-0278-d8ec" name="8.8cm Tank-hunter" hidden="false" collective="false" import="true" type="upgrade">
  <profiles>
    <profile id="0277-80b4-3c8e-a48c" name="8.8cm Tank-hunter" typeId="5cbd-556d-67b5-1bd9" typeName="Command Card" hidden="false">
      <characteristics>
        <characteristic name="Details" typeId="4091-e11a-c858-f46e">This 8.8cm Tank-hunter Platoon may fire an Artillery Bombardment with the following characteristics:
            
                WeaponRangeROF HaltedROF MovingAnti- tankFire- power
