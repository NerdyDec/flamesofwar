</selectionEntry><selectionEntry id="1aec-ab97-9473-e380" name="Heinz Meyer" hidden="false" collective="false" import="true" type="upgrade">
  <profiles>
    <profile id="7811-8a5f-6d24-30b6" name="Heinz Meyer" typeId="5cbd-556d-67b5-1bd9" typeName="Command Card" hidden="false">
      <characteristics>
        <characteristic name="Details" typeId="4091-e11a-c858-f46e">Field a 21st Panzer Panzergrenadier Platoon with 5x MG42 teams (21st Panzer Panzergrenadier Platoon (LG905) as a Support Unit.This Unit and other Units from this Formation whose Unit Leader is within 6”/15cm of this Unit Leader may re-roll any failed Motivation Tests.If any Units are held in Reserve, this Unit must be held in Reserve.</characteristic>
