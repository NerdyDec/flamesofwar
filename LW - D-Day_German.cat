</selectionEntry><selectionEntry id="915e-9eef-b153-3be6" name="Machine-gun Nests" hidden="false" collective="false" import="true" type="upgrade">
  <profiles>
    <profile id="5bf7-d5a6-e745-7151" name="Machine-gun Nests" typeId="5cbd-556d-67b5-1bd9" typeName="Command Card" hidden="false">
      <characteristics>
        <characteristic name="Details" typeId="4091-e11a-c858-f46e">sMG34 or sMG42 HMG teams in this Unit cannot Move, but can rotate to face the target when Shooting, and are Nests.Each HMG team is a separate Independent Team.Nest: The Nests are always Concealed and in Bulletproof Cover.Teams attacking a Nest must re-roll successful Firepower tests to Destroy it.Nests cannot Charge into Contact.LFTF: MG Nests do not use the Beach Defences rules from the D-Day: American book.</characteristic>
        <characteristic name="Notes" typeId="75a6-20ee-1c76-640a">German, Build, Unit (Infantry)</characteristic>
      </characteristics>
    </profile>
    <profile id="d40e-2554-f6c8-7683" name="Forces ID" typeId="86a9-a6ee-b9bd-dafe" typeName="Forces ID" hidden="false">
      <characteristics>
