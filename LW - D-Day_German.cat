      </characteristics>
    </profile>
  </profiles>
  <costs>
    <cost name="pts" typeId="995a-4d67-6920-bfe4" value="2.0"/>
  </costs>
  <categoryLinks>
    <categoryLink id="2f09-a471-c1cb-ba37" name="Command Cards" hidden="false" targetId="c5b6-63ee-3f81-25f2" primary="true"/>
  </categoryLinks>
</selectionEntry><selectionEntry id="64f4-588c-a532-0408" name="Looted Tank" hidden="false" collective="false" import="true" type="upgrade">
  <profiles>
    <profile id="3ae1-d408-268c-ad4c" name="Looted Tank" typeId="5cbd-556d-67b5-1bd9" typeName="Command Card" hidden="false">
      <characteristics>
        <characteristic name="Details" typeId="4091-e11a-c858-f46e">You may field one M5 Stuart (LU103) for 3 points, one M8 Greyhound (LU174) for 2 points, one Sherman (LB102) for 4 points, or one Firefly (LB103) for 5 points, as a Looted Tank.The Looted Tank has a Moving ROF of 1 for any 75mm or 37mm guns, and is an Independent Team with the following ratings:
MOTIVATIONCONFIDENT4+
SKILLTRAINED4+
IS HIT ONAGGRESSIVE3+</characteristic>
        <characteristic name="Notes" typeId="75a6-20ee-1c76-640a"/>
      </characteristics>
    </profile>
    <profile id="a685-6df8-b111-b485" name="Forces ID" typeId="86a9-a6ee-b9bd-dafe" typeName="Forces ID" hidden="false">
