</selectionEntry><selectionEntry id="f214-d3fa-4712-fe60" name="Hans-Ulrich Von Luck" hidden="false" collective="false" import="true" type="upgrade">
  <profiles>
    <profile id="8657-d1bd-b941-8b03" name="Hans-Ulrich Von Luck" typeId="5cbd-556d-67b5-1bd9" typeName="Command Card" hidden="false">
      <characteristics>
        <characteristic name="Details" typeId="4091-e11a-c858-f46e">Von Luck is an Independent SMG team (from 21st Panzer Panzergrenadier Company HQ (LG904)) that functions as a Formation Commander and has the Scout rule.This Team and other Units whose Unit Leader is within 6”/15cm pass all Tactics rolls on 2+.The player may re-roll one die each turn when rolling for Reserves. If any Units are held in Reserve, von Luck must be.</characteristic>
        <characteristic name="Notes" typeId="75a6-20ee-1c76-640a">German, Formation, Warrior (21st Panzer Panzergrenadier Company)</characteristic>
      </characteristics>
    </profile>
    <profile id="8ada-d412-acb1-9b50" name="Forces ID" typeId="86a9-a6ee-b9bd-dafe" typeName="Forces ID" hidden="false">
