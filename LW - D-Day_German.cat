  </categoryLinks>
</selectionEntry><selectionEntry id="6011-f1ac-00bc-d7a2" name="Goliath Remote Control Bomb" hidden="false" collective="false" import="true" type="upgrade">
  <profiles>
    <profile id="2c0a-aa31-264b-30a3" name="Goliath Remote Control Bomb" typeId="5cbd-556d-67b5-1bd9" typeName="Command Card" hidden="false">
      <characteristics>
        <characteristic name="Details" typeId="4091-e11a-c858-f46e">If the Unit Leader did not Move, discard this card to pick an enemy Infantry or Gun Team in Bulletproof Cover, up to 12”/30cm away from, and in Line of Sight of the Unit Leader. Roll a Skill test for the Unit Leader instead of Shooting:If passed, the enemy Team is Hit with a Firepower 3+ weapon and their Unit is Pinned Down. Infantry or Gun Teams must re-roll successful Saves.If the line between the Unit Leader and the enemy Team crosses Terrain more than 2”/5cm from the enemy Team, roll a die for each item of terrain. Any roll that is not 4+ causes the attack to miss. If the line crosses any Impassable Terrain, the attack misses.</characteristic>
        <characteristic name="Notes" typeId="75a6-20ee-1c76-640a">German, Unit (Pioneer Platoon, Panzer Pioneer Platoon)</characteristic>
      </characteristics>
    </profile>
    <profile id="1580-0039-b0c3-7462" name="Forces ID" typeId="86a9-a6ee-b9bd-dafe" typeName="Forces ID" hidden="false">
      <characteristics>
        <characteristic name="ID" typeId="846f-94be-be15-4936">2750faa7-4114-55a3-8dac-69af28350af5</characteristic>
      </characteristics>
    </profile>
  </profiles>
  <costs>
    <cost name="pts" typeId="995a-4d67-6920-bfe4" value="2.0"/>
  </costs>
  <categoryLinks>
    <categoryLink id="1750-9f2d-db02-d53e" name="Command Cards" hidden="false" targetId="c5b6-63ee-3f81-25f2" primary="true"/>
  </categoryLinks>
</selectionEntry><selectionEntry id="78cc-6fbe-ced7-ce37" name="Armoured FlaK Half-tracks" hidden="false" collective="false" import="true" type="upgrade">
  <profiles>
    <profile id="7fa0-88c2-b040-9b7a" name="Armoured FlaK Half-tracks" typeId="5cbd-556d-67b5-1bd9" typeName="Command Card" hidden="false">
      <characteristics>
        <characteristic name="Details" typeId="4091-e11a-c858-f46e">All Sd Kfz 10/4 (2cm) or Sd Kfz 7/1 (Quad 2cm) tanks in this Unit have the following Armour rating instead of their normal Unarmoured Tank Save:
                        ARMOUR
                        
                            
                                
                                    FRONT
                                
                                
                                    0
                                
                                
                                    SIDE &amp; REAR
                                
                                
                                    0
                                
                                
                                    TOP
                                
                                
                                    0</characteristic>
        <characteristic name="Notes" typeId="75a6-20ee-1c76-640a">German, Unit (Sd Kfz 10/4 Light AA Platoon, Sd Kfz 7/1 Quad AA Platoon)</characteristic>
      </characteristics>
    </profile>
    <profile id="1446-e6da-6bcd-ca9d" name="Forces ID" typeId="86a9-a6ee-b9bd-dafe" typeName="Forces ID" hidden="false">
