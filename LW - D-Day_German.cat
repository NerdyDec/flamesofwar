</selectionEntry><selectionEntry id="cc8d-a122-3e0d-4cec" name="Hermann Dropmann" hidden="false" collective="false" import="true" type="upgrade">
  <profiles>
    <profile id="f275-1edc-6ae2-d591" name="Hermann Dropmann" typeId="5cbd-556d-67b5-1bd9" typeName="Command Card" hidden="false">
      <characteristics>
        <characteristic name="Details" typeId="4091-e11a-c858-f46e">In Assaults, the Formation Commander Hits on a roll of 3+. Tanks that he Hits will Save using their Top Armour against his Anti-tank rating of 4. The Formation HQ and any Unit that is making a combined Assault with it Counterattack on a roll of 3+.</characteristic>
        <characteristic name="Notes" typeId="75a6-20ee-1c76-640a">German, Formation, Warrior (Beach Defence Grenadier Company)</characteristic>
      </characteristics>
    </profile>
    <profile id="f8b8-a552-102a-694e" name="Forces ID" typeId="86a9-a6ee-b9bd-dafe" typeName="Forces ID" hidden="false">
      <characteristics>
        <characteristic name="ID" typeId="846f-94be-be15-4936">766b5601-e008-585a-aef3-5d5b0502b49a</characteristic>
      </characteristics>
    </profile>
  </profiles>
