  <profiles>
    <profile id="486b-31c7-aec1-fb49" name="Jochen Peiper" typeId="5cbd-556d-67b5-1bd9" typeName="Command Card" hidden="false">
      <characteristics>
        <characteristic name="Details" typeId="4091-e11a-c858-f46e">Each turn you may re-roll one failed die roll to receive Reserves.
Roll two dice when your Scattered Reserve Unit arrives, choosing one of the dice to determine the location of the Unit’s arrival.
Formation Commander is mounted in a Panther (Late) tank (LG428) in addition to any tanks in the Company HQ Unit.LFTF: This card adds a Panther (late) tank team to the Formation HQ (in addition to the normal 1 or 2 Tiger II or Panther (late) tanks). At the start of the game, the Formation Commander must be mounted in this tank.</characteristic>
        <characteristic name="Notes" typeId="75a6-20ee-1c76-640a">German, Formation, Warrior (Tiger II SS Tank Company, Panther (Late) SS Tank Company)</characteristic>
      </characteristics>
    </profile>
    <profile id="9f53-897f-282f-6e5a" name="Forces ID" typeId="86a9-a6ee-b9bd-dafe" typeName="Forces ID" hidden="false">
