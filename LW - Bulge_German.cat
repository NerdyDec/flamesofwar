        <selectionEntry id="9d59-8e83-3213-3751" name="Kampfgruppe Grabner Armoured Trucks" hidden="false" collective="false" import="true" type="upgrade">
      <profiles>
        <profile id="d862-c3d3-cc92-20ec" name="Kampfgruppe Grabner Armoured Trucks" hidden="false" typeId="5cbd-556d-67b5-1bd9" typeName="Command Card">
          <characteristics>
            <characteristic name="Info" typeId="bd5c-655e-1889-6af7">The trucks that went into combat with Grabner’s assault were reinforced with 55-gallon drums filled with sand and grain, sandbags, and anything else that would offer the slightest bit of protection for the troops inside.</characteristic>
            <characteristic name="Details" typeId="4091-e11a-c858-f46e">This Infantry Unit may add an Armoured Truck Transport Attachment. Add one Armoured Truck Transport for every two Infantry Teams in the Unit.
The characteristics of an Armoured Truck Transport are shown on the back of this card.</characteristic>
            <characteristic name="Notes" typeId="75a6-20ee-1c76-640a">German, Build, Unit (Ardennes SS Reconnaissance Platoon)</characteristic>
          </characteristics>
        </profile>
        <profile id="dffe-f757-ee85-6bef" name="Armoured Truck Transport Attachment" hidden="false" typeId="254c-0270-282e-d058" typeName="Transport Attachment">
          <characteristics>
            <characteristic name="Motivation" typeId="51de-463a-a3e1-ec3b">3+
Counterattack 6
Remount 6</characteristic>
            <characteristic name="Skill" typeId="e62d-94ba-601b-c75c">4+
Assault 6</characteristic>
            <characteristic name="Is Hit On" typeId="860e-e90e-293b-686b">3+</characteristic>
            <characteristic name="Armour Front" typeId="a309-0493-ff5d-7725">0</characteristic>
            <characteristic name="Armour Side &amp; Rear" typeId="8b51-8181-e721-b603">0</characteristic>
            <characteristic name="Armour Top" typeId="e21f-71e9-6da5-f6a6">0</characteristic>
            <characteristic name="Tactical" typeId="b0ef-07bd-45b9-7df3">8&quot;/20cm</characteristic>
            <characteristic name="Terrain Dash" typeId="93f9-5306-09c6-7dd3">8&quot;/20cm</characteristic>
            <characteristic name="Cross Country Dash" typeId="6877-d7fb-c342-2a36">10”/25cm</characteristic>
            <characteristic name="Road Dash" typeId="c6a7-090f-15bd-f02e">28&quot;/70cm</characteristic>
            <characteristic name="Cross" typeId="86c0-d5f3-cd14-602d">5+</characteristic>
            <characteristic name="Notes" typeId="19cb-48c0-b4e8-b529">Passengers 2, Unit Transport</characteristic>
          </characteristics>
        </profile>
        <profile id="9f29-b882-96d8-89d3" name="Armoured Truck (MG)" hidden="false" typeId="33b6-a72a-2bd8-2565" typeName="Weapon">
          <characteristics>
            <characteristic name="Range" typeId="c2e5-4990-8105-f793">16&quot;/40cm</characteristic>
