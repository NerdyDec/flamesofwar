  <profiles>
    <profile id="5f0e-a51f-1075-1f31" name="Tiger Ace" typeId="5cbd-556d-67b5-1bd9" typeName="Command Card" hidden="false">
      <characteristics>
        <characteristic name="Details" typeId="4091-e11a-c858-f46e">Before Deploying this Unit, roll a die and give this Unit the following command card at no additional point cost:1: Clever Hans2: Deadly Gunner3: Rapid Fire4: Schnell!5: Roll Over Them6: Chose one of the above</characteristic>
        <characteristic name="Notes" typeId="75a6-20ee-1c76-640a">German, Unit (Tiger II SS Tank Company HQ, Tiger II Tank Company HQ, Tiger II SS Tank Platoon, Tiger II Tank Platoon, Tiger Tank Platoon)</characteristic>
      </characteristics>
    </profile>
    <profile id="2c66-08c7-a5e8-7f76" name="Forces ID" typeId="86a9-a6ee-b9bd-dafe" typeName="Forces ID" hidden="false">
