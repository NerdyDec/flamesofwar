        <selectionEntry id="0489-4bf5-c7b9-3923" name="SS Panzergrenadier Company" hidden="false" collective="false" import="true" type="upgrade">
      <profiles>
        <profile id="eaaf-753b-5ac8-2123" name="SS Panzergrenadier Company" hidden="false" typeId="5cbd-556d-67b5-1bd9" typeName="Command Card">
          <characteristics>
            <characteristic name="Info" typeId="bd5c-655e-1889-6af7">The SS-Panzergrenadiers in Kampfgruppe Hansen would see combat near Stavelot in an attempt to relieve Kampfgruppe Peiper.</characteristic>
            <characteristic name="Details" typeId="4091-e11a-c858-f46e">Your Force includes a SS Panzergrenadier Company, which is a Formation containing:
• 1	 SS Panzergrenadier Company HQ (LG207)
• 1-2 Ardennes SS Panzergrenadier Platoon (LG442)
• 0-1 Ardennes SS Panzergrenadier Platoon (LG442) 
	 or Ardennes Armoured SS Panzergrenadier Platoon (LG437)
	 or Panzer IV/70 SS Tank-hunter Platoon (LG432)
• 0-1 sMG42 SS Machine-gun Platoon (LG209) 
• 0-1 8cm SS Mortar Platoon (LG210) 
• 0-1 12cm SS Mortar Platoon (LG211) 
