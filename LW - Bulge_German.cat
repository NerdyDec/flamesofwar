        <selectionEntry id="7612-1eb3-41d7-f1ba" name="Rudolf Mobius" hidden="false" collective="false" import="true" type="upgrade">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="a339-b36d-73a6-6e0d" type="max"/>
      </constraints>
      <profiles>
        <profile id="9b91-aee1-0a69-f2af" name="Rudolf Mobius" hidden="false" typeId="5cbd-556d-67b5-1bd9" typeName="Command Card">
          <characteristics>
            <characteristic name="Info" typeId="bd5c-655e-1889-6af7">SS-Hauptsturmfuhrer Rudolf &apos;Rolf&apos; Mobius served in the 1st SS Division&apos;s FlaK battalion where he earned the German Cross in Gold for actions on the Eastern Front in 1943, before transferring to retrain as a tank commander. He failed a staff officer course, but despite this was given command of the 1st Company of the 501st Heavy SS Tank Battalion. During Normandy campaign he even took temporary command of the whole battalion. In the Ardennes he commanded the 2nd Company, taking over from Wittmann, who had been killed in Normandy.</characteristic>
            <characteristic name="Details" typeId="4091-e11a-c858-f46e">The Formation Commander may re-roll all failed rolls To Hit each time he Shoots with his 8.8cm gun.</characteristic>
            <characteristic name="Notes" typeId="75a6-20ee-1c76-640a">German, Formation, Warrior (Tiger II SS Tank Company HQ)</characteristic>
          </characteristics>
        </profile>
      </profiles>
      <categoryLinks>
        <categoryLink id="fc83-27a6-8794-fea0" name="New CategoryLink" hidden="false" targetId="c5b6-63ee-3f81-25f2" primary="true"/>
      </categoryLinks>
      <costs>
        <cost name="pts" typeId="995a-4d67-6920-bfe4" value="5.0"/>
      </costs>
    </selectionEntry>
        <selectionEntry id="be6a-003a-4349-3cdc" name="Panzergrenadier Company" hidden="false" collective="false" import="true" type="upgrade">
      <profiles>
        <profile id="5a02-7a92-47b9-ae01" name="Panzergrenadier Company" hidden="false" typeId="5cbd-556d-67b5-1bd9" typeName="Command Card">
          <characteristics>
            <characteristic name="Info" typeId="bd5c-655e-1889-6af7"/>
            <characteristic name="Details" typeId="4091-e11a-c858-f46e">Your Force includes a Panzergrenadier Company, which is a Formation containing:
• 1	 Panzergrenadier Company HQ (LG170)
• 2	 Ardennes Panzergrenadier Platoon (LG396)
• 0-1 Ardennes Panzergrenadier Platoon (LG396) 
	 or Panther (late) Tank Platoon (LG360)
	 or Panzer IV Tank Platoon (LG167)
	 or StuG Tank Platoon (LG247)
	 or Panzer IV/70 Tank-hunter Platoon (LG361)
• 0-1 sMG34 Machine-gun Platoon (LG122) 
• 0-1 8cm Mortar Platoon (LG116)
• 0-1 12cm Mortar Platoon (LG172)
• 0-1 Armoured 7.5cm Gun Platoon (LG117)
	 or 7.5cm Gun Platoon (LG126)
• 0-1 Grille (late) 15cm Gun Platoon (LG394)
	 or 15cm Gun Platoon (LG127)
• 0-1 Armoured Flame-thrower Platoon (LG119)
• 0-1 7.5cm Tank-hunter Platoon (LG131)
• 0-1 Sd Kfz 10/4 Light AA Platoon (LG142) 
	 or 2cm Light AA Platoon (LG187)</characteristic>
            <characteristic name="Notes" typeId="75a6-20ee-1c76-640a">German, Build, Formation</characteristic>
          </characteristics>
        </profile>
      </profiles>
      <categoryLinks>
        <categoryLink id="874c-b110-c804-0714" name="New CategoryLink" hidden="false" targetId="c5b6-63ee-3f81-25f2" primary="true"/>
      </categoryLinks>
