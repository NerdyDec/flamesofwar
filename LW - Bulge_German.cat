</selectionEntry><selectionEntry id="3080-d439-168c-dfbc" name="Siegfried Moldenhauer" hidden="false" collective="false" import="true" type="upgrade">
  <profiles>
    <profile id="18cc-785d-4087-f796" name="Siegfried Moldenhauer" typeId="5cbd-556d-67b5-1bd9" typeName="Command Card" hidden="false">
      <characteristics>
        <characteristic name="Details" typeId="4091-e11a-c858-f46e">In Assaults, this Formation Commander Hits on a roll of 2+. When conducting a joint Assault all Infantry Teams in the Assaulting Units hit on a roll of one better than their normal Assault rating (4+ to 3+ for example).Any Unit from this Formation whose Unit Leader is within 6”/15cm and Line of Sight of this Formation Commander passes Counterattack and Rally rolls on a 3+.</characteristic>
        <characteristic name="Notes" typeId="75a6-20ee-1c76-640a">German, Formation, Warrior (Volksgrenadier Company)</characteristic>
      </characteristics>
    </profile>
    <profile id="c537-8dc4-2bcd-f3d4" name="Forces ID" typeId="86a9-a6ee-b9bd-dafe" typeName="Forces ID" hidden="false">
      <characteristics>
        <characteristic name="ID" typeId="846f-94be-be15-4936">185ab7b6-ba01-5afb-9c64-0285bd4bf39d</characteristic>
      </characteristics>
    </profile>
