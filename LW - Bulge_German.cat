</selectionEntry><selectionEntry id="e20b-2d26-0bbd-3cfe" name="Hans-Peter Knaust" hidden="false" collective="false" import="true" type="upgrade">
  <profiles>
    <profile id="119f-66fc-aa05-a2f3" name="Hans-Peter Knaust" typeId="5cbd-556d-67b5-1bd9" typeName="Command Card" hidden="false">
      <characteristics>
        <characteristic name="Details" typeId="4091-e11a-c858-f46e">The Formation Commander always passes Range In attempts on a 3+.Each turn you may re-roll one failed die roll to receive Reserves.LFTF: When the Formation Commander makes Range In attempts as a Spotting team, it and the Artillery Battery both count as having Skill 3+.</characteristic>
        <characteristic name="Notes" typeId="75a6-20ee-1c76-640a">German, Formation, Warrior (Brigade Panzergrenadier Company HQ)</characteristic>
      </characteristics>
    </profile>
    <profile id="42bb-0733-c20f-2a0b" name="Forces ID" typeId="86a9-a6ee-b9bd-dafe" typeName="Forces ID" hidden="false">
