        <selectionEntry id="c3a2-6dcb-3085-5b1a" name="Skorzeny&apos;s Commandos Observe Defenses" hidden="false" collective="false" import="true" type="upgrade">
      <profiles>
        <profile id="9f53-081c-4620-1105" name="Skorzeny&apos;s Commandos Observe Defences" hidden="false" typeId="5cbd-556d-67b5-1bd9" typeName="Command Card">
          <characteristics>
            <characteristic name="Info" typeId="bd5c-655e-1889-6af7">The commando teams collected information on enemy defences, troop strength, and other details that would be useful for the advancing German army.</characteristic>
            <characteristic name="Details" typeId="4091-e11a-c858-f46e">Play at the start of a game, after Objectives are placed but before deployment, to move one Objective up to 4&quot;/10cm in any direction.
The Objective;s new location must still follow the mission&apos;s rules for placing Objectives.</characteristic>
            <characteristic name="Notes" typeId="75a6-20ee-1c76-640a">German, Force, Limited</characteristic>
          </characteristics>
        </profile>
      </profiles>
      <categoryLinks>
        <categoryLink id="c68a-4d94-58b5-5930" name="New CategoryLink" hidden="false" targetId="c5b6-63ee-3f81-25f2" primary="true"/>
      </categoryLinks>
      <costs>
        <cost name="pts" typeId="995a-4d67-6920-bfe4" value="2.0"/>
      </costs>
    </selectionEntry>
        <selectionEntry id="736c-2e61-cfcf-9b21" name="Kampfgruppe Grabner" hidden="false" collective="false" import="true" type="upgrade">
      <profiles>
        <profile id="5e62-8dc1-f94b-ed9e" name="Kampfgruppe Grabner" hidden="false" typeId="5cbd-556d-67b5-1bd9" typeName="Command Card">
          <characteristics>
            <characteristic name="Info" typeId="bd5c-655e-1889-6af7">On 17 September 1944, SS-Kampfgruppe Grabner was assembled near Arnhem. These troops were commanded by the eccentric and bold SS-Hauptsturmfuhrer Viktor Grabner.</characteristic>
            <characteristic name="Details" typeId="4091-e11a-c858-f46e">Your Force includes one Kampfgruppe Grabner, which is a Formation containing:
•	1	Reconnaissance Company HQ (LG217)
•	2-3	Ardennes SS Reconnaissance Platoon (LG444)
•	0-1	Sd Kfz 221 &amp; 222 SS Scout Troop (LG224)
•	0-2	Sd Kfz 250 SS Scout Troup (LG223)
•	0-1	Sd Kfz 231 SS Heavy Scout Troop (LG225)
•	0-1	Armoured 7.5cm SS Gun Platoon (LG204) with 3x Sd Kfz 251 (7.5cm) for 4 points
Only one Ardennes SS Reconnaissance Platoon may have Sd Kfz250 (MG) half-tracks.</characteristic>
            <characteristic name="Notes" typeId="75a6-20ee-1c76-640a">German, Build, Formation, Limited</characteristic>
          </characteristics>
        </profile>
      </profiles>
      <categoryLinks>
        <categoryLink id="f93f-a385-0be2-e2c8" name="New CategoryLink" hidden="false" targetId="c5b6-63ee-3f81-25f2" primary="true"/>
      </categoryLinks>
      <selectionEntries>
      </selectionEntries>
      <entryLinks>
      </entryLinks>
      <costs>
        <cost name="pts" typeId="995a-4d67-6920-bfe4" value="0.0"/>
      </costs>
    </selectionEntry>
        <selectionEntry id="1295-b052-7163-9602" name="Kampfgruppe Hummel" hidden="false" collective="false" import="true" type="upgrade">
      <profiles>
        <profile id="68e2-bfbf-7f1f-0bad" name="Kampfgruppe Hummel" hidden="false" typeId="5cbd-556d-67b5-1bd9" typeName="Command Card">
          <characteristics>
            <characteristic name="Info" typeId="bd5c-655e-1889-6af7">Kampfgruppe Hummel was a training unit, equipped with old, worn-out Tiger I heavy tanks.</characteristic>
            <characteristic name="Details" typeId="4091-e11a-c858-f46e">Your Force includes one Kampfgruppe Hummel, which is a Formation containing:
•	1	Tiger Tank Company HQ (LG244)
•	2-3	Tiger Tank Platoon (LG102)
Units in this Formation have the following ratings for -4 points per Tiger Tank team.</characteristic>
            <characteristic name="Notes" typeId="75a6-20ee-1c76-640a">German, Build, Formation, Limited</characteristic>
          </characteristics>
        </profile>
      </profiles>
      <categoryLinks>
        <categoryLink id="5afa-0881-b9c2-acb8" name="New CategoryLink" hidden="false" targetId="c5b6-63ee-3f81-25f2" primary="true"/>
        <categoryLink id="4f6a-4ece-5dce-adf7" name="Formations" hidden="false" targetId="5630-abd3-15d8-5cc6" primary="false"/>
      </categoryLinks>
      <entryLinks>
      <entryLink id="ebec-cf3a-3b06-a0ee" name="Tiger Tank Platoon (LG102)" hidden="false" collective="false" import="true" targetId="7114-faa3-af81-b43a" type="selectionEntry"/></entryLinks>
      <costs>
        <cost name="pts" typeId="995a-4d67-6920-bfe4" value="0.0"/>
      </costs>
    </selectionEntry>
        <selectionEntry id="c5cb-3174-7177-ed95" name="106. Panzer Brigade Feldherrnhalle Experienced Panzergrenadier" hidden="false" collective="false" import="true" type="upgrade">
      <profiles>
        <profile id="c69f-e374-b642-7676" name="106. Panzer Brigade Feldherrnhalle Experienced Panzergrenadiers" hidden="false" typeId="5cbd-556d-67b5-1bd9" typeName="Command Card">
          <characteristics>
            <characteristic name="Info" typeId="bd5c-655e-1889-6af7">The fighting in Lorraine taught the Brigade many lessons and they soon adapted to the enemy’s tactics.</characteristic>
            <characteristic name="Details" typeId="4091-e11a-c858-f46e">All Infantry Units in this Formation have the following ratings for:
Brigade Armoured Unit		Full Str		Under Str
Assault Company HQ			+1 point		-
