    <profile id="1f50-89d4-2bb4-a31a" name="Wespe (10.5cm) [Direct]" hidden="false" typeId="33b6-a72a-2bd8-2565" typeName="Weapon">
      <characteristics>
        <characteristic name="Range" typeId="c2e5-4990-8105-f793">72&quot;/180cm</characteristic>
