      </characteristics>
    </profile>
  </profiles>
  <costs>
    <cost name="pts" typeId="995a-4d67-6920-bfe4" value="2.0"/>
  </costs>
  <categoryLinks>
    <categoryLink id="3da2-5a44-ad3a-de01" name="Command Cards" hidden="false" targetId="c5b6-63ee-3f81-25f2" primary="true"/>
  </categoryLinks>
</selectionEntry><selectionEntry id="030e-7f1e-4c82-984f" name="Panzer Brigade Sd Kfz 251 Half-track Transport" hidden="false" collective="false" import="true" type="upgrade">
  <profiles>
    <profile id="7d47-93ca-a01d-f17f" name="Panzer Brigade Sd Kfz 251 Half-track Transport" typeId="5cbd-556d-67b5-1bd9" typeName="Command Card" hidden="false">
      <characteristics>
        <characteristic name="Details" typeId="4091-e11a-c858-f46e">This Gun Unit may add an Sd Kfz 251 halftrack transport Attachment. The number of vehicles in the Unit is as follows:Add one Sd Kfz 251 (MG) half-track transport for each Gun Team in the Unit.The characteristics of an Sd Kfz 251 half-track transport are shown on the Brigade Sd Kfz 251 half-track transport (LG376) card. The Transport Attachment loses Mounted Assault and Passenger 3, and gains Tractor:Tractor: Can carry one Gun Team as Passengers.</characteristic>
        <characteristic name="Notes" typeId="75a6-20ee-1c76-640a">German, Build, Unit (Brigade 12cm Mortar Platoon)</characteristic>
      </characteristics>
