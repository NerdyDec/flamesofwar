        <selectionEntry id="776e-d58c-5c77-2c15" name="Reconnaissance Kampfgruppe" hidden="false" collective="false" import="true" type="upgrade">
      <profiles>
        <profile id="9d69-375e-b359-7cd2" name="Reconnaissance Kampfgruppe" hidden="false" typeId="5cbd-556d-67b5-1bd9" typeName="Command Card">
          <characteristics>
            <characteristic name="Info" typeId="bd5c-655e-1889-6af7">Both 2nd Panzer and Panzer Lehr Divisions led their Ardennes offensive advance with their reconnaissance battalions supported by panzers.</characteristic>
            <characteristic name="Details" typeId="4091-e11a-c858-f46e">Your Force includes one Reconnaissance Kampfgruppe Hansen Vanguard, which is a Formation containing:
• 1	 Reconnaissance Company HQ (LG256)
• 1-2 Ardennes Reconnaissance Platoon (LG399)
• 1	 Ardennes Reconnaissance Platoon (LG399)
	 or Panther (late) Tank Platoon (LG360)
	 or Panzer IV Tank Platoon (LG167)
