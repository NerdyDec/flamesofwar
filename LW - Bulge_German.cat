    <profile id="d542-b975-5b5e-35a9" name="Armoured Flak Half-Tracks" hidden="false" typeId="5cbd-556d-67b5-1bd9" typeName="Command Card">
      <characteristics>
        <characteristic name="Info" typeId="bd5c-655e-1889-6af7">By 1944 many of the self-propelled anti-aircraft units were armoured to protect them from small arms fire and shrapnel.</characteristic>
        <characteristic name="Details" typeId="4091-e11a-c858-f46e">All Sd Kfz 10/4 (2cm) tanks in this Unit have the following Armour rating instead of their normal Unarmoured Tank Save:ARMOURFRONT0SIDE &amp; REAR0TOP0</characteristic>
        <characteristic name="Notes" typeId="75a6-20ee-1c76-640a">German, Unit (Sd Kfz 10/4 Light AA Platoon)</characteristic>
      </characteristics>
    </profile>
    <profile id="b15e-af63-0f1e-9b82" name="Sd Kfz 10/4 Light AA Platoon (Armoured)" publicationId="3bbf-3707-35dd-b1f5" page="100" hidden="false" typeId="55ec-3ef5-ca51-e647" typeName="Tank Unit">
